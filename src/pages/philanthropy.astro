---
import Layout from '~/layouts/PageLayout.astro';
import HeroKintsugi from '~/components/widgets/v2/HeroKintsugi.astro';
import ContentKintsugi from '~/components/widgets/v2/ContentKintsugi.astro';
import FeaturesSeam from '~/components/widgets/v2/FeaturesSeam.astro';
import CTASumi from '~/components/widgets/v2/CTASumi.astro';

const metadata = {
  title: 'Philanthropy',
  description: 'Preserving Japanese culture and empowering communities',
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->
  <HeroKintsugi
    eyebrow="§ 01 / PHILANTHROPY"
    titleEn="Preserving Japanese Culture and Empowering Communities"
    titleJa="日本文化の保護とコミュニティの支援"
    subtitle="A dedicated philanthropic practice focused on cultural preservation, scholarships, and mental health — with a predominant focus on the Japanese market."
    primaryLang="en"
  />

  <!-- Intro ******************* -->
  <ContentKintsugi
    id="intro"
    eyebrow="§ 02 / APPROACH"
    title="A practice of partnership and patience."
    intro="Deerfield Green is a dedicated philanthropic firm with a strong focus on the preservation of Japanese culture, supporting scholarships, and promoting mental health initiatives, particularly in the areas of suicide prevention and domestic abuse. With a predominant focus on the Japanese market, we strive to make a meaningful impact by partnering with notable non-profit organizations that share our vision and have a primary mission in these critical areas."
    items={[
      {
        title: 'Long-horizon partnerships',
        description:
          'We build enduring relationships with organizations whose mission aligns with our own, rather than one-off grants.',
      },
      {
        title: 'Measurable impact',
        description:
          'We value transparency, accountability, and measurable outcomes, ensuring grants are deployed effectively.',
      },
      {
        title: 'Japan-focused',
        description:
          'A predominant focus on the Japanese market, its cultural heritage, and its communities in need.',
      },
    ]}
  />

  <!-- Focus Areas ******************* -->
  <FeaturesSeam
    id="focus"
    eyebrow="§ 03 / FOCUS AREAS"
    title="Three areas of commitment."
    subtitle="Where we concentrate our giving and our attention."
    items={[
      {
        label: 'CULTURE',
        title: 'Cultural Preservation',
        description:
          'Investing in initiatives that promote and safeguard Japanese culture, including the preservation of traditional arts, crafts, festivals, historical sites, and cultural education programs.',
      },
      {
        label: 'SCHOLARSHIPS',
        title: 'Scholarships',
        description:
          'Providing financial support and resources to deserving students, creating pathways for excellence and contributing to the development of future leaders, thinkers, and innovators.',
      },
      {
        label: 'MENTAL HEALTH',
        title: 'Mental Health',
        description:
          'Supporting organizations that provide counseling, awareness campaigns, helplines, and other crucial resources for suicide prevention and domestic abuse support.',
      },
      {
        label: 'COMMUNITY',
        title: 'Community & Opportunity',
        description:
          'Creating pathways to opportunity through education, vocational training, and entrepreneurship initiatives that uplift individuals and communities.',
      },
    ]}
  />

  <!-- Cultural Preservation ******************* -->
  <ContentKintsugi
    id="culture"
    eyebrow="§ 04 / CULTURAL PRESERVATION"
    title="Safeguarding the roots."
    intro="At Deerfield Green, our primary objective is to preserve and celebrate the rich cultural heritage of Japan. We believe that cultural preservation is essential for the identity and well-being of a society. By investing in initiatives that promote and safeguard Japanese culture, we aim to ensure that future generations can embrace and learn from their historical roots. We support organizations that engage in activities such as the preservation of traditional arts, crafts, festivals, historical sites, and cultural education programs."
    items={[]}
    image={{
      src: '~/assets/images/philanthropy-culture.jpg',
      alt: 'Traditional Japanese temple pathway surrounded by greenery',
    }}
  />
  <div class="max-w-7xl mx-auto px-6 md:px-10 -mt-6 mb-12 text-right">
    <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-[var(--aw-color-text-subtle)]">
      Photo by <a href="https://unsplash.com/@remi_b?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Rémi Bertogliati</a> · <a href="https://unsplash.com/?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Unsplash</a>
    </p>
  </div>

  <!-- Scholarships ******************* -->
  <ContentKintsugi
    id="scholarships"
    eyebrow="§ 05 / SCHOLARSHIPS"
    title="Pathways for excellence."
    intro="Recognizing the importance of education and knowledge, Deerfield Green places a significant emphasis on scholarships. We firmly believe that education is the key to unlocking opportunities and empowering individuals to realize their full potential. By providing financial support and resources to deserving students, we aim to create pathways for excellence and contribute to the development of future leaders, thinkers, and innovators who will shape Japan's future."
    items={[]}
    image={{
      src: '~/assets/images/philanthropy-scholarships.jpg',
      alt: 'Japanese students in school uniforms',
    }}
    isReversed
  />
  <div class="max-w-7xl mx-auto px-6 md:px-10 -mt-6 mb-12 text-right">
    <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-[var(--aw-color-text-subtle)]">
      Photo by <a href="https://unsplash.com/@duonguyen?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">DuoNguyen</a> · <a href="https://unsplash.com/?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Unsplash</a>
    </p>
  </div>

  <!-- Mental Health ******************* -->
  <ContentKintsugi
    id="mental-health"
    eyebrow="§ 06 / MENTAL HEALTH"
    title="A society that prioritizes well-being."
    intro="In addition to cultural preservation and scholarships, Deerfield Green is deeply committed to mental health initiatives, with a particular focus on suicide prevention and domestic abuse. We understand the urgent need to address these pressing societal challenges and support organizations that work tirelessly to provide counseling, awareness campaigns, helplines, and other crucial resources. By funding programs that promote mental health, reduce stigma, and offer support to individuals in crisis, we strive to create a society that prioritizes emotional well-being and provides a safe environment for all."
    items={[]}
    image={{
      src: '~/assets/images/philanthropy-mental-health.jpg',
      alt: 'Community support and mental wellness',
    }}
  />
  <div class="max-w-7xl mx-auto px-6 md:px-10 -mt-6 mb-12 text-right">
    <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-[var(--aw-color-text-subtle)]">
      Photo by <a href="https://unsplash.com/@shamimnakhaei?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Shamim Nakhaei</a> · <a href="https://unsplash.com/?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Unsplash</a>
    </p>
  </div>

  <!-- Approach ******************* -->
  <ContentKintsugi
    id="grants"
    eyebrow="§ 07 / APPROACH"
    title="A grant-making practice built on patience."
    intro="Central to our approach is the annual grant-making process, where we carefully select notable non-profit organizations that align with our core mission. We value transparency, accountability, and measurable impact, ensuring that our grants are utilized effectively to maximize positive outcomes. By establishing long-term partnerships and fostering collaboration among diverse stakeholders, we aim to create a sustainable and lasting change in the areas we support."
    items={[]}
    image={{
      src: '~/assets/images/philanthropy-approach.jpg',
      alt: 'Team collaboration and partnership',
    }}
    isReversed
  />
  <div class="max-w-7xl mx-auto px-6 md:px-10 -mt-6 mb-12 text-right">
    <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-[var(--aw-color-text-subtle)]">
      Photo by <a href="https://unsplash.com/@camylla93?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Camylla Battani</a> · <a href="https://unsplash.com/?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Unsplash</a>
    </p>
  </div>

  <!-- CTA ******************* -->
  <CTASumi
    id="contact"
    eyebrow="§ 08 / CONTACT"
    titleEn="Support our mission."
    titleJa="共に歩みましょう。"
    subtitle="Learn more about our philanthropic initiatives and partnership opportunities."
    actions={[{ variant: 'primary', text: 'Begin a conversation', href: '/contact/' }]}
    primaryLang="en"
  />
</Layout>

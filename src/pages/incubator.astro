---
import Layout from '~/layouts/PageLayout.astro';

import HeroKintsugi from '~/components/widgets/v2/HeroKintsugi.astro';
import ContentKintsugi from '~/components/widgets/v2/ContentKintsugi.astro';
import FeaturesSeam from '~/components/widgets/v2/FeaturesSeam.astro';
import CTASumi from '~/components/widgets/v2/CTASumi.astro';

const metadata = {
  title: 'Incubator',
  description:
    'An incubator-style venture capital model bridging Japanese innovation with global healthcare markets, nurturing healthcare, biotech, and AI-powered medical innovations.',
};
---

<Layout metadata={metadata}>
  <HeroKintsugi
    eyebrow="§ 01 / INCUBATOR"
    titleEn="Bridging Japanese innovation with global healthcare markets."
    titleJa="日本のイノベーションと世界のヘルスケア市場の架け橋。"
    subtitle="An incubator-style venture capital model representing a unique synthesis of Eastern and Western business philosophies, specifically designed to nurture healthcare, biotech, and AI-powered medical innovations."
    actions={[{ text: 'Begin a conversation', href: '/contact/' }]}
    primaryLang="en"
  />

  <ContentKintsugi
    id="thesis"
    eyebrow="§ 02 / THESIS"
    title="Engineering tomorrow's healthcare innovation through cross-Pacific partnership."
    image={{ src: '~/assets/images/incubator.jpg', alt: 'Incubator Program' }}
    intro="At Deerfield Green, we believe that the future of healthcare innovation lies at the intersection of Japanese technological excellence, deep cultural wisdom, and global market reach. Our incubator-style venture capital model represents a unique synthesis of Eastern and Western business philosophies, specifically designed to nurture healthcare, biotech, and AI-powered medical innovations from Japan's extraordinary research ecosystem to global market leadership."
    items={[
      {
        title: '25 years bridging Japan and the United States',
        description:
          "Drawing from our team's collective 25 years of experience building and scaling SaaS revenue companies across both Japanese and American markets, we've architected an incubator model that bridges two of the world's most sophisticated healthcare ecosystems.",
      },
      {
        title: 'More than capital',
        description:
          "We understand that Japan's healthcare innovation — from regenerative medicine breakthroughs to AI-powered diagnostics — requires not just capital, but cultural fluency, operational excellence, and the ability to navigate both Japanese precision and American speed-to-market dynamics.",
      },
      {
        title: 'The power of "Wa" in portfolio management',
        description:
          'Unlike traditional Western venture capital firms that prioritize aggressive growth at all costs, Deerfield Green embraces the Japanese principle of "wa" (harmony) in our portfolio approach. We maintain a deliberately concentrated portfolio of no more than 10 healthcare startups at any given time, ensuring each company receives the patient, thoughtful support characteristic of Japanese business relationships while maintaining the urgency required for global market competition.',
      },
    ]}
  />

  <FeaturesSeam
    id="philosophy"
    eyebrow="§ 03 / PHILOSOPHY"
    title="Our investment philosophy: harmonizing Japanese excellence with global ambition."
    subtitle="Four disciplines that shape how we partner with founders from first conversation through global scale."
    items={[
      {
        label: 'NEMAWASHI',
        title: 'Long-term relationship building',
        description:
          'We invest 6-18 months in relationship development before investment, understanding not just the technology but the people, their values, and their vision for societal impact.',
      },
      {
        label: 'CONSENSUS',
        title: 'Consensus-driven decision making',
        description:
          'Major strategic decisions involve all stakeholders, respecting the Japanese tradition of collective wisdom while maintaining entrepreneurial agility.',
      },
      {
        label: 'FOUNDER VISION',
        title: 'Preservation of founder vision',
        description:
          "Unlike aggressive Western restructuring, we honor the founder's original mission while providing the operational support to achieve global scale.",
      },
      {
        label: 'PATIENT CAPITAL',
        title: 'Patient capital approach',
        description:
          'Aligned with Japanese investment philosophy, we maintain 5-7 year investment horizons, allowing innovations to mature properly.',
      },
    ]}
  />

  <FeaturesSeam
    id="focus"
    eyebrow="§ 04 / FOCUS AREAS"
    title="Healthcare innovation at the convergence of cultures."
    subtitle="With 30% of Japan's population over 65 and 10% over 80, Japan serves as the world's laboratory for aging society solutions. Our portfolio companies solve problems that every developed nation will face within a decade."
    items={[
      {
        label: 'LONGEVITY',
        title: 'Longevity and anti-aging therapeutics',
        description: "Leveraging Japan's Blue Zone philosophies with cutting-edge biotechnology.",
      },
      {
        label: 'ELDERLY CARE',
        title: 'AI-powered elderly care solutions',
        description: 'Combining robotics, AI, and human-centered design for dignified aging.',
      },
      {
        label: 'REGENERATIVE',
        title: 'Regenerative medicine',
        description: "Building on Japan's regulatory advantages in cell therapy and tissue engineering.",
      },
      {
        label: 'DIGITAL THERAPEUTICS',
        title: 'Digital therapeutics',
        description: 'Addressing the unique challenges of multi-morbidity in aging populations.',
      },
      {
        label: 'DIAGNOSTICS',
        title: 'AI-powered diagnostics and precision medicine',
        description:
          "Leveraging Japan's superior medical imaging datasets, universal healthcare records, and genetic databases to develop cutting-edge AI diagnostic tools.",
      },
      {
        label: 'BIOTECH',
        title: 'Biotechnology and pharmaceutical innovation',
        description:
          "From regenerative medicine leadership to fragment-based drug discovery, leveraging Japan's strengths in structural biology and protein engineering.",
      },
      {
        label: 'DIGITAL HEALTH',
        title: 'Digital health and telemedicine',
        description:
          "Japan's digital health market projected to reach 90.87 billion by 2035. Platforms addressing fragmented healthcare delivery and rural access.",
      },
    ]}
  />

  <ContentKintsugi
    id="regulatory"
    eyebrow="§ 05 / REGULATORY"
    title="The regulatory advantage."
    isReversed
    intro="Japan offers unique regulatory pathways that accelerate innovation, and our deep relationships with regulatory authorities and understanding of both PMDA and FDA requirements enable portfolio companies to leverage Japan as a springboard to global markets."
    items={[
      {
        title: 'Conditional Approval System',
        description: 'A pathway for regenerative medicines that compresses the path from bench to bedside.',
      },
      {
        title: 'Sakigake Designation',
        description: 'Accelerated review for breakthrough therapies with meaningful clinical promise.',
      },
      {
        title: 'Collaborative PMDA consultations',
        description:
          'Ongoing, collaborative engagement with the regulator that de-risks development and clarifies requirements early.',
      },
    ]}
  />

  <ContentKintsugi
    id="bridge"
    eyebrow="§ 06 / JAPAN–US BRIDGE"
    title="Turning regional innovation into global impact."
    intro="Our two-hub structure in Tokyo and Atlanta forms a powerful corridor for healthcare innovation."
    items={[
      {
        title: 'Tokyo operations: the innovation hub',
        description:
          "Direct access to Japan's 6.2 billion government funding programs for pharmaceutical startups; partnerships with leading institutions like University of Tokyo, Keio, and RIKEN; proximity to Japan's Greater Tokyo Biocommunity, housing 50% of the nation's biotech startups; and relationships with Japanese pharmaceutical giants seeking innovation partnerships.",
      },
      {
        title: 'Atlanta operations: the commercialization engine',
        description:
          "Gateway to the $4.3 trillion US healthcare market; proximity to CDC, Emory University, and Georgia Tech's biomedical engineering programs; access to the Southeast's emerging biotech corridor; and direct connections to US venture capital and strategic acquirers.",
      },
    ]}
  />

  <FeaturesSeam
    id="cultural-translation"
    eyebrow="§ 07 / CULTURAL TRANSLATION"
    title="The cultural translation layer."
    subtitle="Success in cross-Pacific healthcare ventures requires more than literal translation — it demands cultural interpretation and adaptation."
    items={[
      {
        label: 'CONCEPT',
        title: 'Concept adaptation',
        description:
          'Japanese innovations often emphasize subtlety and prevention; we help translate these into value propositions that resonate with Western outcome-focused healthcare systems.',
      },
      {
        label: 'CLINICAL',
        title: 'Clinical trial strategy',
        description:
          "Leveraging Japan's ethnically homogeneous population for proof-of-concept, then expanding to diverse populations for global validation.",
      },
      {
        label: 'BUSINESS MODEL',
        title: 'Business model translation',
        description:
          'Converting Japanese relationship-based business models to scalable, metrics-driven approaches demanded by Western investors.',
      },
      {
        label: 'IP',
        title: 'IP strategy',
        description:
          'Navigating the differences between Japanese collaborative R&D culture and Western IP protection requirements.',
      },
    ]}
  />

  <FeaturesSeam
    id="operations"
    eyebrow="§ 08 / OPERATIONS"
    title="Japanese precision meets Silicon Valley speed."
    subtitle='Our operational framework combines the art of "Omotenashi" in B2B healthcare with US market entry strategy, creating a powerful bridge for portfolio companies.'
    items={[
      {
        label: 'TRUST',
        title: 'Building trust before transactions',
        description:
          'Japanese healthcare institutions require extensive relationship development; we facilitate 6-12 month engagement cycles.',
      },
      {
        label: 'STAKEHOLDERS',
        title: 'Multi-stakeholder navigation',
        description:
          'Understanding the complex decision-making involving doctors, administrators, and government officials.',
      },
      {
        label: 'ITERATION',
        title: 'Perfection through iteration',
        description:
          'Embracing the Japanese approach of relentless refinement while balancing market timing requirements.',
      },
      {
        label: 'CROSS-PACIFIC',
        title: 'Cross-Pacific development teams',
        description:
          '24-hour development cycles leveraging time zones, with bilingual documentation and regulatory-compliant architecture.',
      },
    ]}
  />

  <CTASumi
    id="contact"
    eyebrow="§ 09 / CONTACT"
    titleEn="Partner with us."
    titleJa="一緒に取り組みませんか。"
    subtitle="Learn how our incubator model bridges Japanese innovation with global healthcare markets."
    actions={[{ text: 'Begin a conversation', href: '/contact/', variant: 'primary' }]}
    primaryLang="en"
  />
</Layout>

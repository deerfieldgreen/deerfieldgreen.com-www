---
import Layout from '~/layouts/PageLayout.astro';

import HeroKintsugi from '~/components/widgets/v2/HeroKintsugi.astro';
import FeaturesSeam from '~/components/widgets/v2/FeaturesSeam.astro';
import ContentKintsugi from '~/components/widgets/v2/ContentKintsugi.astro';
import CTASumi from '~/components/widgets/v2/CTASumi.astro';

const metadata = {
  title: 'Deerfield Green — Strategic Consulting & Quantitative Investment',
  description:
    'Deerfield Green is a boutique firm combining AI-driven quantitative investment, SaaS consulting, healthcare private equity, and purposeful philanthropy from Tokyo, Japan.',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <!-- Hero (Kintsugi) ************************************************ -->

  <HeroKintsugi
    eyebrow="DEERFIELD GREEN · 東京 / ATLANTA · MMXXVI"
    titleEn="Thoughtful. Patient.<br/>Quantitative."
    titleJa="思慮深く、辛抱強く、定量的に。"
    subtitle="Strategic consulting, quantitative investment, and purposeful philanthropy — from Tokyo to global markets."
    actions={[
      { text: 'Begin a conversation', href: '/contact/' },
      { text: 'About the firm', href: '/about/' },
    ]}
  />

  <!-- Offerings (FeaturesSeam) *************************************** -->

  <FeaturesSeam
    id="practice"
    eyebrow="§ 02 / OFFERINGS"
    title="Our Practice"
    subtitle="Six disciplines, one patient-capital philosophy."
    defaultLinkText="Learn more →"
    items={[
      {
        label: 'QUANT / AI',
        title: 'Investment',
        description:
          'Algorithms, machine learning, and AI-driven strategic investment in NYSE and NASDAQ — managing risk and generating alpha through non-correlated returns.',
        href: '/investment/',
      },
      {
        label: 'SAAS / AI STRATEGY',
        title: 'Services',
        description:
          'SaaS subscription-revenue consulting and AI product strategy — where data-driven growth meets intelligent innovation.',
        href: '/services/',
      },
      {
        label: 'HEALTHCARE / VC',
        title: 'Incubator',
        description:
          'Bridging Japanese innovation with global healthcare markets through an incubator-style venture capital model.',
        href: '/incubator/',
      },
      {
        label: 'HEALTHCARE / PE',
        title: 'Private Equity',
        description:
          "Japan's healthcare revolution through patient capital — operational excellence delivering exceptional returns.",
        href: '/private-equity/',
      },
      {
        label: 'CULTURE / CARE',
        title: 'Philanthropy',
        description:
          'Japanese cultural preservation, scholarship support, and mental-health advocacy — with a focus on suicide prevention and domestic abuse.',
        href: '/philanthropy/',
      },
      {
        label: 'CULTURE / FIRM',
        title: 'Life @DFG',
        description:
          'A place of intellectual exploration. We value curiosity, embrace diverse passions, and foster a culture of continuous learning.',
        href: '/life/',
      },
    ]}
  />

  <!-- Firm (ContentKintsugi) ***************************************** -->

  <ContentKintsugi
    id="firm"
    eyebrow="§ 03 / FIRM"
    title="Where eastern wisdom<br/>meets western innovation."
    intro="Deerfield Green bridges Japanese technological excellence with global market reach — a strategic consulting and quantitative investment firm built on patient capital and bicultural fluency."
    image={{ src: '~/assets/images/team-work.jpg', alt: 'Deerfield Green — Tokyo and Atlanta' }}
    items={[
      {
        title: 'Cross-Pacific Expertise',
        description:
          'Over 25 years building and scaling companies across Japanese and American markets — bicultural fluency in every engagement.',
      },
      {
        title: 'Patient Capital Philosophy',
        description:
          'Aligned with the Japanese principle of "wa" (harmony) — a long-term view, investing in relationships, operational excellence, and sustainable growth.',
      },
      {
        title: 'Technology-Driven Approach',
        description:
          'Proprietary algorithms, machine learning models, and AI-powered analysis surface opportunities with unusual accuracy.',
      },
    ]}
  />

  <!-- Contact (CTASumi) ********************************************** -->

  <CTASumi
    id="contact"
    eyebrow="§ 04 / CONTACT"
    titleEn="Let's talk."
    titleJa="お話ししましょう。"
    subtitle="Whether you're seeking strategic consulting, investment partnership, or cross-Pacific market expertise — we'd like to hear from you."
    actions={[
      { text: 'Begin a conversation', href: '/contact/', variant: 'primary' },
      { text: 'Read our thesis', href: '/about/' },
    ]}
  />
</Layout>

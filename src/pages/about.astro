---
import Layout from '~/layouts/PageLayout.astro';
import HeroKintsugi from '~/components/widgets/v2/HeroKintsugi.astro';
import ContentKintsugi from '~/components/widgets/v2/ContentKintsugi.astro';
import FeaturesSeam from '~/components/widgets/v2/FeaturesSeam.astro';
import CTASumi from '~/components/widgets/v2/CTASumi.astro';

const metadata = {
  title: 'About Deerfield Green',
  description:
    'Learn about Deerfield Green, a private quantitative investment firm based in Tokyo, Japan, blending strategic investing with purposeful philanthropy.',
};
---

<Layout metadata={metadata}>
  <!-- Hero ************************ -->

  <HeroKintsugi
    eyebrow="§ 01 / ABOUT"
    titleEn="Thoughtful.<br/>Patient.<br/>Quantitative."
    titleJa="思慮深く。忍耐強く。定量的に。"
    subtitle="A boutique investment and consulting firm bridging Japanese excellence with global markets — combining quantitative rigor, cross-Pacific expertise, and purposeful philanthropy."
    actions={[{ text: 'Begin a conversation', href: '/contact/' }]}
  />

  <!-- Mission ********************* -->

  <ContentKintsugi
    id="mission"
    eyebrow="§ 02 / MISSION"
    title="Our Mission"
    intro="Deerfield Green is a private quantitative investment firm based in Minato-ku, Tokyo, Japan. Our mission is twofold: seeking alpha across global markets and channeling the yields from our portfolio into philanthropic endeavors that make a positive impact on society. We firmly believe that capitalistic endeavors can be blended with a deep sense of purpose to empower and improve the lives of others."
    items={[
      {
        title: 'Alpha with Purpose',
        description:
          'We apply quantitative strategies to identify and capture alpha in global markets, leveraging data-driven models and rigorous analysis.',
      },
      {
        title: 'Philanthropy at the Center',
        description:
          'Our investment thesis centers around the singular purpose of philanthropy — from Japanese cultural preservation and scholarships to mental health advocacy.',
      },
      {
        title: 'Sustainable Impact',
        description:
          'By generating strong financial returns, we ensure the sustainability and growth of our philanthropic initiatives over the long term.',
      },
    ]}
    image={{
      src: '~/assets/images/team-work.jpg',
      alt: 'Deerfield Green team collaboration',
    }}
  />

  <!-- Practice ******************** -->

  <FeaturesSeam
    id="services"
    eyebrow="§ 03 / PRACTICE"
    title="Our Services"
    subtitle="Four practices, one thesis — quantitative rigor and patient capital in service of purpose."
    items={[
      {
        label: 'QUANT / AI',
        title: 'Investment',
        description:
          'AI-driven quantitative investment in NYSE and NASDAQ, focused on managing risk and generating alpha through non-correlated returns.',
      },
      {
        label: 'AI / SAAS',
        title: 'Services',
        description:
          'AI product strategy and SaaS subscription revenue consulting — where data-driven growth meets intelligent innovation.',
      },
      {
        label: 'HEALTHCARE / VC',
        title: 'Incubator',
        description:
          'Bridging Japanese innovation with global healthcare markets through an incubator-style venture capital model.',
      },
      {
        label: 'HEALTHCARE / PE',
        title: 'Private Equity',
        description:
          "Japan's healthcare revolution through patient capital — operational excellence delivering exceptional returns.",
      },
    ]}
  />

  <!-- Values ********************** -->

  <ContentKintsugi
    id="values"
    eyebrow="§ 04 / VALUES"
    title="Our Values"
    intro="Guided by principles that bridge Eastern wisdom with Western innovation."
    isReversed={true}
    items={[
      {
        title: 'Patient Capital Philosophy',
        description:
          'In practice: multi-year horizons on Japan healthcare private equity and incubator positions, with capital aligned to operating teams and clinical milestones rather than quarterly targets.',
      },
      {
        title: 'Cross-Pacific Expertise',
        description:
          'In practice: navigating Japanese regulatory pathways for medical innovation, adapting Silicon Valley SaaS go-to-market for the Japanese enterprise buyer, and acting as the cultural translation layer between U.S. founders and Japanese partners.',
      },
      {
        title: 'Technology-Driven Approach',
        description:
          'In practice: proprietary quantitative strategies running on NYSE and NASDAQ for risk-managed alpha, and AI product strategy engagements that tie model choices and inference costs back to measurable business outcomes.',
      },
    ]}
  />

  <!-- Locations ******************* -->

  <FeaturesSeam
    id="locations"
    eyebrow="§ 05 / LOCATIONS"
    title="Where We Work"
    items={[
      {
        label: 'JAPAN / HQ',
        title: 'Minato-ku, Tokyo, Japan',
        description: 'Our headquarters in the heart of Tokyo.',
      },
      {
        label: 'USA / OFFICE',
        title: 'Milton, Georgia',
        description: 'Our U.S. office in the greater Atlanta area.',
      },
    ]}
  />

  <!-- CTA ************************* -->

  <CTASumi
    eyebrow="§ 06 / CONTACT"
    titleEn="Let's build together."
    titleJa="ご一緒に築きましょう。"
    subtitle="Whether you're seeking strategic consulting, investment partnership, or cross-Pacific market expertise, we'd love to hear from you."
    actions={[{ text: 'Get in touch', href: '/contact/', variant: 'primary' }]}
  />
</Layout>

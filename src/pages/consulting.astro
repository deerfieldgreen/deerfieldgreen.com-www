---
import Layout from '~/layouts/PageLayout.astro';

import HeroText from '~/components/widgets/HeroText.astro';
import Content from '~/components/widgets/Content.astro';
import Features from '~/components/widgets/Features.astro';

const metadata = {
  title: 'Consulting',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Consulting"
    title="Helping SaaS Businesses Grow Their Subscription Revenue"
    subtitle="Deerfield Green is a management consulting firm that helps SaaS businesses grow their subscription revenue. We have helped over 40 clients across Silicon Valley, healthcare, and manufacturing to pivot, accelerate, and grow their ARR portfolios."
  />

  <!-- Content Widget **************** -->

  <Content
    image={{
      src: '~/assets/images/team-work.jpg',
      alt: 'Consulting Team',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-4">How Deerfield Green Can Help</h3>
      <p class="mb-4">
        Deerfield Green is a management consulting firm that helps SaaS businesses grow their subscription revenue. We have helped over 40 clients across Silicon Valley, healthcare, and manufacturing to pivot, accelerate, and grow their ARR portfolios.
      </p>
      <p class="mb-4">
        We do this by working with our clients to develop and implement a comprehensive subscription revenue growth strategy. This strategy takes into account the specific needs of the business, the target market, and the competitive landscape.
      </p>
      <p class="mb-4">
        We also help our clients to improve their sales and marketing processes, optimize their pricing strategy, and build a strong customer retention program.
      </p>
      <p class="mb-4">
        If you are looking to grow your subscription revenue, Deerfield Green can help. Contact us today to learn more about our services.
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- Features Widget *************** -->

  <Features
    title="How We Help Our Clients Succeed"
    subtitle="Deerfield Green covers a variety of topics related to SaaS businesses. We believe that a holistic approach is essential for achieving sustainable growth. By addressing all of these areas, we can help our clients to build successful and profitable SaaS businesses."
    items={[
      {
        title: 'Direct and Channel Sales',
        description:
          'Building and optimizing direct and channel sales strategies to maximize reach and revenue.',
        icon: 'tabler:users',
      },
      {
        title: 'Subscription Marketing Strategy',
        description:
          'Developing targeted marketing strategies designed to acquire and retain subscription customers.',
        icon: 'tabler:speakerphone',
      },
      {
        title: 'Data Strategy',
        description:
          'Leveraging data analytics to inform decision-making and drive business growth.',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'Finance',
        description:
          'Financial planning and modeling to ensure sustainable growth and profitability.',
        icon: 'tabler:calculator',
      },
      {
        title: 'Product Led Growth',
        description:
          'Implementing product-led growth strategies that drive adoption and expansion revenue.',
        icon: 'tabler:rocket',
      },
    ]}
  />
</Layout>

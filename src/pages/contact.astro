---
import Layout from '~/layouts/PageLayout.astro';
import HeroKintsugi from '~/components/widgets/v2/HeroKintsugi.astro';
import FeaturesSeam from '~/components/widgets/v2/FeaturesSeam.astro';
import ContactForm from '~/components/widgets/Contact.astro';
import PaperGrain from '~/components/common/PaperGrain.astro';
import SeamDivider from '~/components/common/SeamDivider.astro';

const metadata = {
  title: 'Contact Us',
  description: 'Get in touch with the Deerfield Green team in Tokyo and Atlanta',
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->
  <HeroKintsugi
    eyebrow="§ 01 / CONTACT"
    titleEn="Get in Touch."
    titleJa="お問い合わせ。"
    subtitle="Got an idea? Use the form below to shoot us a message and we'll get back to you within a few days."
    primaryLang="en"
  />

  <!-- Contact Form (preserved widget, wrapped in Kintsugi aesthetic) -->
  <section class="relative bg-[var(--aw-color-bg-page)] py-16 md:py-24">
    <PaperGrain tone="light" opacity={0.03} />
    <div class="max-w-7xl mx-auto px-6 md:px-10 relative">
      <SeamDivider variant="default" tone="light" class="mb-16" />
      <ContactForm
        id="form"
        title="Leave a Message"
        subtitle="We'd love to hear from you. Fill out the form below and our team will respond promptly."
        inputs={[
          { type: 'text', name: 'name', label: 'Name' },
          { type: 'email', name: 'email', label: 'Email' },
        ]}
        textarea={{ label: 'Message' }}
        disclaimer={{
          label:
            'By submitting this contact form, you acknowledge and agree to the collection of your personal information.',
        }}
        description="Our team typically responds within a few business days."
      />
    </div>
  </section>

  <!-- Locations ******************* -->
  <FeaturesSeam
    id="locations"
    eyebrow="§ 02 / LOCATIONS"
    title="Find us."
    items={[
      {
        label: 'JAPAN / HQ',
        title: 'Tokyo, Japan',
        description: 'Minato-ku, Tokyo.',
      },
      {
        label: 'USA / OFFICE',
        title: 'Milton, Georgia',
        description: 'Milton, Georgia (greater Atlanta area).',
      },
    ]}
  />

  <!-- Online ******************* -->
  <FeaturesSeam
    id="online"
    eyebrow="§ 03 / ONLINE"
    title="Connect."
    items={[
      {
        label: 'LINKEDIN / FOLLOW',
        title: 'LinkedIn',
        description: 'Follow Deerfield Green on LinkedIn',
        href: 'https://www.linkedin.com/company/deerfieldgreen/',
        linkText: 'Follow Deerfield Green on LinkedIn →',
      },
    ]}
  />
</Layout>

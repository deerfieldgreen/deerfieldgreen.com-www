---
import Layout from '~/layouts/PageLayout.astro';
import HeroKintsugi from '~/components/widgets/v2/HeroKintsugi.astro';
import ContentKintsugi from '~/components/widgets/v2/ContentKintsugi.astro';
import FeaturesSeam from '~/components/widgets/v2/FeaturesSeam.astro';
import CTASumi from '~/components/widgets/v2/CTASumi.astro';

const metadata = {
  title: 'Life @DFG',
  description: 'A haven for intellectual exploration and innovation',
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->
  <HeroKintsugi
    eyebrow="§ 01 / LIFE AT DFG"
    titleEn="A Haven for Intellectual Exploration."
    titleJa="知的探求の場。"
    subtitle="A community of intellectually curious individuals who share a love for ideas, a thirst for knowledge, and a commitment to the geeky and nerdy passions that lead to breakthrough work."
    primaryLang="en"
  />

  <!-- Curiosity ******************* -->
  <ContentKintsugi
    id="culture"
    eyebrow="§ 02 / CURIOSITY"
    title="Culture."
    intro="Deerfield Green is a unique firm that fosters a culture of intellectual curiosity, embracing the geeky and nerdy passions of its diverse and vibrant team. At Deerfield Green, our people are perpetually hungry for new knowledge, techniques, and ideas, driven by an insatiable desire to learn and explore. We are a community of individuals who thrive on sharing knowledge, seeking out the experiences of others, and engaging in open and respectful discussions."
    items={[
      {
        title: 'A shared love for intellectual pursuits',
        description:
          'We celebrate the geeky and nerdy aspects of our team, recognizing that unconventional interests often lead to the most groundbreaking and innovative ideas.',
      },
      {
        title: 'Passion channeled into work',
        description:
          'Our people are deeply passionate about their areas of expertise and infuse the entire organization with a sense of excitement and discovery.',
      },
    ]}
    image={{
      src: '~/assets/images/workforce-960x540.jpg.webp',
      alt: 'Culture at Deerfield Green',
    }}
  />

  <!-- Collaboration ******************* -->
  <ContentKintsugi
    id="collaboration"
    eyebrow="§ 03 / COLLABORATION"
    title="Collaboration."
    intro="At Deerfield Green, we understand that true intellectual growth comes from collaboration and a constant thirst for new perspectives. Our team actively seeks out the knowledge and experience of others, recognizing that each individual brings a unique set of insights to the table. We foster an environment where sharing knowledge is not only encouraged but celebrated, enabling our team to collectively expand their horizons and push the boundaries of what's possible."
    items={[
      {
        title: 'The bigger picture',
        description:
          'Individuals possess a deep understanding of how their work fits into the broader context, allowing them to see connections and patterns others miss.',
      },
      {
        title: 'Fresh perspectives daily',
        description:
          'Each day brings new approaches and the excitement of discovering unexplored possibilities.',
      },
    ]}
    image={{ src: '~/assets/images/team-work.jpg', alt: 'Teamwork at Deerfield Green' }}
    isReversed
  />

  <!-- Openness ******************* -->
  <ContentKintsugi
    id="openness"
    eyebrow="§ 04 / OPENNESS"
    title="Open & inclusive."
    intro="The culture at Deerfield Green is open and inclusive, where every individual's voice is respected and valued. We believe that diversity of thought and opinion is crucial for stimulating intellectual discourse and fostering a truly dynamic and innovative environment. We encourage our team members to express their ideas freely, knowing that their contributions are valued and will be met with open minds. This culture of openness creates a safe space for collaboration, where ideas can be refined, expanded upon, and transformed into meaningful outcomes."
    items={[
      {
        title: 'A community, not just a firm',
        description:
          'With a thirst for knowledge, a drive for exploration, and a commitment to sharing ideas, our team propels us forward on a continuous journey of growth and innovation.',
      },
    ]}
    image={{
      src: '~/assets/images/team-1.jpg',
      alt: 'Team collaboration at Deerfield Green',
    }}
  />

  <!-- Locations ******************* -->
  <FeaturesSeam
    id="locations"
    eyebrow="§ 05 / LOCATIONS"
    title="Where we work."
    items={[
      {
        label: 'JAPAN / HQ',
        title: 'Minato-ku, Tokyo',
        description: 'Our headquarters in the heart of Tokyo.',
      },
      {
        label: 'USA / OFFICE',
        title: 'Milton, Georgia',
        description: 'Our U.S. office in the greater Atlanta area.',
      },
    ]}
  />

  <!-- CTA ******************* -->
  <CTASumi
    id="contact"
    eyebrow="§ 06 / CONTACT"
    titleEn="Curious about working with us?"
    titleJa="私たちと共に働きませんか。"
    subtitle="Reach out to learn more about life at Deerfield Green."
    actions={[{ variant: 'primary', text: 'Begin a conversation', href: '/contact/' }]}
    primaryLang="en"
  />
</Layout>

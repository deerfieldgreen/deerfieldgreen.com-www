---
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'コンサルティング',
  description: 'SaaSビジネスのサブスクリプション収益の成長を支援',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="コンサルティング"
    title="SaaSビジネスのサブスクリプション収益の成長を支援"
  />

  <!-- Consulting Content ******************* -->

  <Content
    id="consulting"
    columns={1}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">ディアフィールド・グリーンがお手伝いできること</h3>
      <p class="text-lg text-muted mb-4">
        ディアフィールド・グリーンは、SaaSビジネスのサブスクリプション収益の成長を支援する経営コンサルティング会社です。シリコンバレー、ヘルスケア、製造業など40社以上のクライアントのピボット、アクセラレート、ARRポートフォリオの成長を支援してきました。
      </p>
      <p class="text-lg text-muted mb-4">
        私たちは、包括的なサブスクリプション収益成長戦略を策定し、実施するためにお客様と協力することでこれを実現します。この戦略では、ビジネスの具体的なニーズ、ターゲット市場、競合状況を考慮します。
      </p>
      <p class="text-lg text-muted mb-4">
        また、営業・マーケティングプロセスの改善、価格戦略の最適化、強力な顧客維持プログラムの構築など、クライアント企業を支援します。
      </p>
      <p class="text-lg text-muted">
        サブスクリプション収益の拡大をお考えなら、ディアフィールド・グリーンがお手伝いいたします。今すぐお問い合わせください。
      </p>
    </Fragment>
  </Content>

  <!-- Service Areas ******************* -->

  <Features2
    title="サービス分野"
    tagline="成功のお手伝い"
    columns={3}
    items={[
      {
        title: 'ダイレクト・セールスおよびチャネル・セールス',
        description: '効果的な販売チャネルの構築と最適化を支援',
        icon: 'tabler:target-arrow',
      },
      {
        title: 'サブスクリプション・マーケティング戦略',
        description: '持続的な成長を実現するマーケティング戦略を策定',
        icon: 'tabler:speakerphone',
      },
      {
        title: 'データ戦略',
        description: 'データドリブンな意思決定を可能にする基盤を構築',
        icon: 'tabler:database',
      },
      {
        title: 'ファイナンス',
        description: '財務モデリングとサブスクリプション収益の最適化',
        icon: 'tabler:calculator',
      },
      {
        title: '製品主導の成長',
        description: 'プロダクト・レッド・グロース戦略の設計と実装',
        icon: 'tabler:rocket',
      },
    ]}
  />

  <!-- Holistic Approach ******************* -->

  <Content
    id="approach"
    isReversed
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">総合的アプローチ</h3>
      <p class="text-lg text-muted">
        私たちは、持続可能な成長を実現するためには、総合的なアプローチが不可欠であると考えています。これらの分野すべてに取り組むことで、クライアントが成功し、利益を生むSaaSビジネスを構築できるよう支援します。
      </p>
    </Fragment>
  </Content>
</Layout>

---
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'チーム',
  description: 'クオンツ投資と目的を持った慈善活動の融合',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="チーム"
    title="クオンツ投資と目的を持った慈善活動の融合"
  />

  <!-- Mission Content ******************* -->

  <Content
    id="mission"
    columns={1}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">私たちの使命</h3>
      <p class="text-lg text-muted mb-4">
        ディアフィールド・グリーンは東京都港区に本社を置くクオンツ投資会社です。私たちの使命は2つあります。それは、グローバル市場でアルファを追求すること、そして私たちのポートフォリオから得られる利回りを、社会にポジティブな影響を与える慈善活動に振り向けることです。私たちは、資本主義的な努力は、他の人々の生活に力を与え、向上させるという深い目的意識と融合させることができると確信しています。
      </p>
      <p class="text-lg text-muted mb-4">
        ディアフィールド・グリーンは、フィランソロピーという唯一の目的を中心に投資活動を行っています。データドリブンモデルと厳密な分析を活用し、定量的投資戦略を適用して、グローバル市場でアルファを特定し、獲得します。強力な財務リターンを創出することで、社会貢献活動の持続可能性と成長を確保し、重要な分野で意義のある変化をもたらすことを可能にしています。
      </p>
      <p class="text-lg text-muted mb-4">
        私たちは、日本の文化・芸術の支援と保護に重点を置いています。私たちは、文化遺産が社会の形成やアイデンティティの育成に果たすかけがえのない役割を認識しています。慈善活動を通じて、私たちは日本文化の保護を促進し、芸術的才能を育成し、文化表現のプラットフォームを提供するイニシアティブに投資しています。
      </p>
      <p class="text-lg text-muted mb-4">
        ディアフィールド・グリーンはまた、恵まれない人々のための機会開発にも深くコミットしています。成功への道筋を作り、生活の質を高めることで、個人と地域社会に力を与えることができると信じています。私たちの慈善活動は、教育プログラム、職業訓練、起業家精神を支援することで、恵まれない人々の潜在能力を最大限に引き出し、持続可能な未来を築くことを目的としています。
      </p>
      <p class="text-lg text-muted mb-4">
        ディアフィールド・グリーンは、メンタルヘルスの成長の重要性を認識し、メンタルヘルスの問題に取り組み、感情的な幸福を促進する取り組みに多大なリソースを捧げています。私たちは、この重要な分野でカウンセリング、セラピー、啓発キャンペーン、研究を行っている団体を支援しています。
      </p>
      <p class="text-lg text-muted mb-4">
        ディアフィールド・グリーンは、クオンツ戦略を推進する一方で、他者の生活を向上させるという強い人間性を特徴とするブティック・ファームとしての経験を提供しています。ディアフィールド・グリーンは、思いやりのある個別的なアプローチが持つ力を理解し、投資判断が慈善活動の目標と一致するよう徹底しています。
      </p>
      <p class="text-lg text-muted">
        要約すると、ディアフィールド・グリーンは東京を拠点とするプライベート・クオンツ投資会社であり、目的のある慈善活動に深くコミットしている。私たちは、グローバル市場でアルファを追求する一方、ポートフォリオから得られる利回りを、日本の文化や芸術、困窮している人々への機会提供、メンタルヘルスの成長といった分野に投資しています。資本主義的な努力と力強い人生の目的を融合させることで、社会にポジティブな影響を与え、人々の生活を向上させることを目指しています。
      </p>
    </Fragment>
  </Content>

  <!-- Founder ******************* -->

  <Content
    id="founder"
    isReversed
    image={{
      src: '~/assets/images/team-1.jpg',
      alt: 'ケビン・ストール',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">ケビン・オニール・ストール</h3>
      <p class="text-xl font-semibold text-primary mb-4">創設者</p>
      <p class="text-lg text-muted mb-4">
        米国ジョージア州アルファレッタ出身のケビン・ストールは、サブスクリプション・エコノミー企業の成長戦略に関する20年以上のアドバイザリー経験を持つ。金融市場と日本文化に深い関心を持つデータマニアであり、多様な視点を組み合わせてインパクトのある結果を導く。
      </p>
      <p>
        <a href="https://www.linkedin.com/in/Kevinostoll" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">
          LinkedInでつながる &rarr;
        </a>
      </p>
    </Fragment>
  </Content>

  <!-- Additional Team Roles ******************* -->

  <Features2
    title="チームメンバー"
    tagline="役職"
    columns={2}
    items={[
      {
        title: '主任研究員',
        description: '',
        icon: 'tabler:search',
      },
      {
        title: 'クオンツ・アナリスト',
        description: '',
        icon: 'tabler:chart-bar',
      },
    ]}
  />
</Layout>

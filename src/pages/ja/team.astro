---
import Layout from '~/layouts/PageLayout.astro';
import HeroKintsugi from '~/components/widgets/v2/HeroKintsugi.astro';
import ContentKintsugi from '~/components/widgets/v2/ContentKintsugi.astro';
import CTASumi from '~/components/widgets/v2/CTASumi.astro';

const metadata = {
  title: 'チーム',
  description: 'クオンツ投資と目的を持った慈善活動の融合',
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->
  <HeroKintsugi
    eyebrow="§ 01 / チーム"
    titleEn="Blending Quantitative Investing with Purposeful Philanthropy"
    titleJa="クオンツ投資と目的ある慈善活動の融合"
    subtitle="ブティック・ファームとしての経験——金融の専門性と、他者の生活を向上させるという強い人間性を兼ね備えています。"
    primaryLang="ja"
  />

  <!-- Founder ******************* -->
  <ContentKintsugi
    id="founder"
    eyebrow="§ 02 / 創設者"
    title="ケビン・オニール・ストール"
    intro={`<span class="block font-mono text-[11px] tracking-[0.22em] uppercase text-[var(--aw-color-primary)] mb-4">創設者</span>米国ジョージア州アルファレッタ出身のケビン・ストールは、サブスクリプション・エコノミー企業の成長戦略に関する20年以上のアドバイザリー経験を持ちます。金融市場と日本文化に深い関心を持つデータマニアであり、多様な視点を組み合わせてインパクトのある結果を導きます。<br/><br/><a href="https://www.linkedin.com/company/deerfieldgreen/" target="_blank" rel="noopener noreferrer" class="kintsugi-link font-sans text-[14px] tracking-wide">ディアフィールド・グリーンを LinkedIn でフォロー →</a>`}
    items={[
      { title: '東京・アトランタ', description: '東京都港区とアトランタ郊外を拠点としています。' },
      { title: '20年以上のアドバイザリー', description: 'サブスクリプション・エコノミー企業の成長戦略支援。' },
      { title: 'データと日本文化', description: '金融市場と日本文化に深い関心を持つデータマニア。' },
    ]}
    image={{ src: '~/assets/images/team-1.jpg', alt: 'ケビン・ストール' }}
    isReversed
  />

  <!-- Mission ******************* -->
  <ContentKintsugi
    id="mission"
    eyebrow="§ 03 / 使命"
    title="目的に奉仕するアルファ。"
    intro="ディアフィールド・グリーンは東京都港区に本社を置くクオンツ投資会社です。私たちの使命は2つあります。それは、グローバル市場でアルファを追求すること、そして私たちのポートフォリオから得られる利回りを、社会にポジティブな影響を与える慈善活動に振り向けることです。私たちは、資本主義的な努力は、他の人々の生活に力を与え、向上させるという深い目的意識と融合させることができると確信しています。"
    items={[
      {
        title: 'クオンツ投資の論理',
        description:
          'データドリブンモデルと厳密な分析を用い、グローバル市場でアルファを特定・獲得することで、慈善活動の持続可能性と成長を支えます。',
      },
      {
        title: '日本の文化と芸術',
        description:
          '日本文化の保護を促進し、芸術的才能を育成し、文化表現のプラットフォームを提供する取り組みに投資します。',
      },
      {
        title: '恵まれない人々への機会',
        description:
          '教育プログラム、職業訓練、起業支援を通じて、個人の潜在能力を引き出し、持続可能な未来を築きます。',
      },
      {
        title: 'メンタルヘルスの推進',
        description:
          'カウンセリング、セラピー、啓発キャンペーン、研究を通じて、心の健康とレジリエンスを優先する社会を支援します。',
      },
      {
        title: 'ブティック・ファーム体験',
        description:
          'クオンツ戦略を推進する一方で、他者の生活を向上させるという強い人間性を特徴とするブティック体験を提供します。',
      },
    ]}
  />

  <!-- CTA ******************* -->
  <CTASumi
    id="contact"
    eyebrow="§ 04 / お問い合わせ"
    titleEn="Start a conversation."
    titleJa="お話ししましょう。"
    subtitle="投資、慈善活動、あるいは共通の関心事について——お気軽にお声がけください。"
    actions={[{ variant: 'primary', text: 'お問い合わせ', href: '/ja/contact/' }]}
    primaryLang="ja"
  />
</Layout>

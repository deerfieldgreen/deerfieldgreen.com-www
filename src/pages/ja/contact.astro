---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: '連絡先',
  description: 'お問い合わせ',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText tagline="連絡先" title="お問い合わせ" />

  <ContactUs
    id="form"
    title="メッセージを残す"
    subtitle="アイデアをお持ちですか？このフォームを使ってメッセージをお送りください。"
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'お名前',
      },
      {
        type: 'email',
        name: 'email',
        label: 'メールアドレス',
      },
    ]}
    textarea={{
      label: 'メッセージ',
    }}
    disclaimer={{
      label:
        'このお問い合わせフォームを送信することにより、お客様の個人情報の収集に同意したものとみなされます。',
    }}
    description="通常、24営業時間以内にご返信いたします。"
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="お気軽にお問い合わせください"
    items={[
      {
        title: 'メール',
        description: 'contact@deerfieldgreen.com',
        icon: 'tabler:mail',
      },
      {
        title: '所在地',
        description: '東京都港区 / ジョージア州ミルトン',
        icon: 'tabler:map-pin',
      },
    ]}
  />
</Layout>

---
import Layout from '~/layouts/PageLayout.astro';

import HeroKintsugi from '~/components/widgets/v2/HeroKintsugi.astro';
import ContentKintsugi from '~/components/widgets/v2/ContentKintsugi.astro';
import FeaturesSeam from '~/components/widgets/v2/FeaturesSeam.astro';
import CTASumi from '~/components/widgets/v2/CTASumi.astro';
import SeamDivider from '~/components/common/SeamDivider.astro';

const metadata = {
  title: 'サービス',
  description: 'AIプロダクト戦略とSaaSサブスクリプション収益コンサルティング — インテリジェントなイノベーションとデータドリブンな成長の融合。',
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->

  <HeroKintsugi
    eyebrow="§ 01 / サービス"
    titleEn="AI Product Strategy &amp; SaaS Growth"
    titleJa="AI プロダクト戦略 と SaaS グロース"
    subtitle="2つの専門分野をワンストップで。AI導入とサブスクリプション成長を一体化し、インテリジェントなプロダクトを持続的なARRへと積み上げていきます。"
    actions={[
      {
        variant: 'primary',
        text: 'お問い合わせ',
        href: '/ja/contact/',
      },
    ]}
    primaryLang="ja"
  />

  <!-- AI Product Strategy — narrative + image ******************* -->

  <ContentKintsugi
    id="ai"
    eyebrow="§ 02 / AI プロダクト戦略"
    title="インテリジェントなビジョンと、測定可能なインパクトの融合。"
    intro="ディアフィールド・グリーンは、先進的なリーダーと協力し、人工知能を「可能性」から「成果」へと変革します。顧客体験を再定義するだけでなく、資本効率とオペレーショナルROIを推進するAI対応プロダクトの設計とスケーリングを支援します。"
    items={[
      {
        title: '目的の明確化と、測定可能な変化。',
        description:
          '効果的なAI戦略は、事業課題の明確化から始まり、成果の変化で終わります。ビジョナリーなプロダクト思考と、実践的な実行力を組み合わせます。',
      },
      {
        title: '自己強化型のシステムとモデル。',
        description:
          'AI投資が複利的に積み上がるシステムとビジネスモデルを設計します。より良いデータがより良い機能を生み、より良い機能が次のデータを生む構造です。',
      },
      {
        title: '経営陣・プロダクト・データの連携。',
        description:
          '経営陣、プロダクトチーム、データリーダーと協力し、全社的なAIビジョン、スケーラブルなアーキテクチャ、収益化の道筋、透明性のあるガバナンスを構築します。',
      },
    ]}
    image={{ src: '~/assets/images/services-ai.jpg', alt: 'AIテクノロジーとデータビジュアライゼーション' }}
  />

  <!-- Unsplash attribution — AI image ******************* -->

  <div class="max-w-7xl mx-auto px-6 md:px-10 -mt-6 mb-12 text-right">
    <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-[var(--aw-color-text-subtle)]">
      Photo by <a href="https://unsplash.com/@growtika?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Growtika</a> · <a href="https://unsplash.com/?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Unsplash</a>
    </p>
  </div>

  <!-- AI Strategy services — seam list ******************* -->

  <FeaturesSeam
    id="ai-services"
    eyebrow="§ 03 / AI アドバイザリー"
    title="AI戦略サービス"
    subtitle="AIを組織全体で持続的にスケールさせるためのシステムと規律の構築。"
    defaultLinkText="詳細 →"
    items={[
      {
        label: 'ROI',
        title: 'AI ROIモデリング',
        description:
          '詳細なパフォーマンス指標、投資回収分析、成長予測を通じて、投資をビジネス成果に結びつけます。',
      },
      {
        label: 'EFFICIENCY',
        title: 'インテリジェント・コスト効率化',
        description:
          '最適化された推論パイプライン、キャッシング戦略、適応型モデルルーティングによりトークンレベルのOpExを削減します。',
      },
      {
        label: 'MONETIZATION',
        title: '機能主導の収益化',
        description:
          'パーソナライゼーション、予測、自動化などのAI主導の価値提案を創出し、収益またはリテンション向上に直結させます。',
      },
      {
        label: 'WORKFORCE',
        title: 'ワークフォース・リイマジネーション',
        description:
          'AI拡張されたロールと継続的学習を通じて、タスク実行から高次の問題解決へとチームの転換を支援します。',
      },
      {
        label: 'CONTINUITY',
        title: 'データ＆プロダクト継続性',
        description:
          'データ、モデル、実験のライフサイクルシステムを確立し、イノベーションを進化する市場ニーズに整合させます。',
      },
    ]}
  />

  <SeamDivider variant="default" tone="light" />

  <!-- SaaS Subscription Growth — narrative + image ******************* -->

  <ContentKintsugi
    id="saas"
    eyebrow="§ 04 / SaaS グロース"
    title="複利的に積み上がる、サブスクリプション収益。"
    intro="ディアフィールド・グリーンは、得意とする3つの領域 — シリコンバレーSaaS、ヘルステック、産業・製造テクノロジー — でSaaSビジネスのサブスクリプション収益成長を支援しています。40社を超える支援実績の中心にあるのは、ARRの拡大、解約率の低減、価格・パッケージの見直しという一貫したテーマです。"
    items={[
      {
        title: '事業の現在地から始める。',
        description:
          'どのコホートから離脱が起きているか、どのセグメントが割安な価格になっているか、どのプロダクトがリテンションを支えているか。各プロジェクトはその診断から始まります。テンプレートは使いません。',
      },
      {
        title: '市場の実態に即した計画。',
        description:
          '市場、買い手、競合環境に即したサブスクリプション収益計画を設計します。価格・パッケージ、GTMモデル、リテンションプログラムを一貫して設計します。',
      },
      {
        title: '複数年にわたり積み上がるARR。',
        description:
          'ダイレクト、チャネル、プロダクト・レッドの各モーションとリテンション・エクスパンションを組み合わせ、成長が自走する構造を作ります。',
      },
    ]}
    image={{ src: '~/assets/images/services-saas.jpg', alt: 'チームによるブレインストーミングと戦略策定' }}
    isReversed={true}
  />

  <!-- Unsplash attribution — SaaS image ******************* -->

  <div class="max-w-7xl mx-auto px-6 md:px-10 -mt-6 mb-12 text-right">
    <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-[var(--aw-color-text-subtle)]">
      Photo by <a href="https://unsplash.com/@silverkblack?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Vitaly Gariev</a> · <a href="https://unsplash.com/?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Unsplash</a>
    </p>
  </div>

  <!-- SaaS Advisory — seam list ******************* -->

  <FeaturesSeam
    id="saas-services"
    eyebrow="§ 05 / SaaS アドバイザリー"
    title="SaaS成長サービス"
    subtitle="持続可能なサブスクリプション収益成長のための総合的アプローチ。"
    defaultLinkText="詳細 →"
    items={[
      {
        label: 'SALES',
        title: 'ダイレクト・セールスおよびチャネル・セールス',
        description:
          '効果的な販売チャネルの構築と最適化を支援します。',
      },
      {
        label: 'MARKETING',
        title: 'サブスクリプション・マーケティング戦略',
        description:
          '持続的な成長を実現するマーケティング戦略を策定します。',
      },
      {
        label: 'DATA',
        title: 'データ戦略',
        description:
          'データドリブンな意思決定を可能にする基盤を構築します。',
      },
      {
        label: 'FINANCE',
        title: 'ファイナンス',
        description:
          '財務モデリングとサブスクリプション収益の最適化を支援します。',
      },
      {
        label: 'PLG',
        title: '製品主導の成長',
        description:
          'プロダクト・レッド・グロース戦略の設計と実装を支援します。',
      },
    ]}
  />

  <!-- CTA ******************* -->

  <CTASumi
    eyebrow="§ 06 / お問い合わせ"
    titleEn="Ready to transform your business?"
    titleJa="ビジネスの変革を、ともに。"
    subtitle="インテリジェントなプロダクト戦略と、持続的なサブスクリプション成長をどう結びつけるか。ぜひお聞かせください。"
    actions={[
      {
        variant: 'primary',
        text: 'お問い合わせ',
        href: '/ja/contact/',
      },
    ]}
    primaryLang="ja"
  />
</Layout>

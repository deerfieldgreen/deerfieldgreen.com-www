---
import Layout from '~/layouts/PageLayout.astro';

import HeroText from '~/components/widgets/HeroText.astro';
import Content from '~/components/widgets/Content.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
  title: 'サービス',
  description: 'SaaSサブスクリプション収益コンサルティングとAIプロダクト戦略 — データドリブンな成長とインテリジェントなイノベーションの融合。',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="サービス"
    title="SaaS成長戦略 & AIプロダクト戦略"
    subtitle="ディアフィールド・グリーンは、SaaSサブスクリプション収益の専門知識と先進的なAIプロダクト戦略を融合し、企業の定期収益の拡大と次世代インテリジェント・プロダクトの構築を支援します。"
  />

  <!-- Intro Narrative ******************* -->

  <Content
    id="intro"
    columns={1}
  >
    <Fragment slot="content">
      <p class="text-lg text-muted mb-4">
        最も成功しているテクノロジー企業は、サブスクリプション成長とAI導入を別々の取り組みとして扱いません。この2つを一体化させています。より強力なデータ戦略がよりスマートなAI機能を生み出し、インテリジェントな自動化が解約率を低減し、顧客生涯価値を向上させます。AI主導のパーソナライゼーションが、既存のサブスクリプションモデル内に新たな収益化の道を切り開きます。
      </p>
      <p class="text-lg text-muted">
        ディアフィールド・グリーンは、この2つの専門分野をワンストップで提供します。ARRの加速、AI対応プロダクトラインの立ち上げ、またはその両方が必要な場合でも、イノベーションと経済的価値を結びつける意思決定を支援します。
      </p>
    </Fragment>
  </Content>

  <!-- SaaS Consulting Section ******************* -->

  <Content
    id="saas"
    image={{
      src: '~/assets/images/team-work.jpg',
      alt: 'コンサルティングチーム',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-4">SaaSサブスクリプション収益</h3>
      <p class="mb-4">
        ディアフィールド・グリーンは、SaaSビジネスのサブスクリプション収益の成長を支援する経営コンサルティング会社です。シリコンバレー、ヘルスケア、製造業など40社以上のクライアントのピボット、アクセラレート、ARRポートフォリオの成長を支援してきました。
      </p>
      <p class="mb-4">
        ビジネスの具体的なニーズ、ターゲット市場、競合状況を考慮した包括的なサブスクリプション収益成長戦略の策定と実施をお客様と協力して進めます。
      </p>
      <p class="mb-4">
        また、営業・マーケティングプロセスの改善、価格戦略の最適化、強力な顧客維持プログラムの構築を支援します。
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- SaaS Features ******************* -->

  <Features
    title="SaaS成長サービス"
    subtitle="持続可能なサブスクリプション収益成長のための総合的アプローチ。"
    items={[
      {
        title: 'ダイレクト・セールスおよびチャネル・セールス',
        description:
          '効果的な販売チャネルの構築と最適化を支援します。',
        icon: 'tabler:users',
      },
      {
        title: 'サブスクリプション・マーケティング戦略',
        description:
          '持続的な成長を実現するマーケティング戦略を策定します。',
        icon: 'tabler:speakerphone',
      },
      {
        title: 'データ戦略',
        description:
          'データドリブンな意思決定を可能にする基盤を構築します。',
        icon: 'tabler:chart-bar',
      },
      {
        title: 'ファイナンス',
        description:
          '財務モデリングとサブスクリプション収益の最適化を支援します。',
        icon: 'tabler:calculator',
      },
      {
        title: '製品主導の成長',
        description:
          'プロダクト・レッド・グロース戦略の設計と実装を支援します。',
        icon: 'tabler:rocket',
      },
    ]}
  />

  <!-- AI Product Strategy Section ******************* -->

  <Content
    id="ai"
    isReversed
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-4">AIプロダクト戦略</h3>
      <p class="text-xl text-muted mb-4">インテリジェントなビジョンと測定可能なインパクトの融合</p>
      <p class="mb-4">
        ディアフィールド・グリーンは、先進的なリーダーと協力し、人工知能を「可能性」から「成果」へと変革します。顧客体験を再定義するだけでなく、資本効率とオペレーショナルROIを推進するAI対応プロダクトの設計とスケーリングを支援します。
      </p>
      <p class="mb-4">
        効果的なAI戦略は、目的の明確化から始まり、測定可能な変化で終わると私たちは考えています。ビジョナリーなプロダクト思考と実践的な実行力を組み合わせ、AI投資を自己強化型にするシステムとビジネスモデルを構築します。
      </p>
      <p class="mb-4">
        経営陣、プロダクトチーム、データリーダーと協力し、全社的なAIビジョンの定義、スケーラブルなアーキテクチャの設計、インテリジェント機能の収益化、ワークフォース変革の推進、透明性のあるガバナンスフレームワークの構築を支援します。
      </p>
    </Fragment>

    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- AI Features ******************* -->

  <Features2
    title="AI戦略サービス"
    subtitle="AIを組織全体で持続的にスケールさせるためのシステムと規律の構築。"
    columns={3}
    items={[
      {
        title: 'AI ROIモデリング',
        description:
          '詳細なパフォーマンス指標、投資回収分析、成長予測を通じて、投資をビジネス成果に結びつけます。',
        icon: 'tabler:chart-dots-3',
      },
      {
        title: 'インテリジェント・コスト効率化',
        description:
          '最適化された推論パイプライン、キャッシング戦略、適応型モデルルーティングによりトークンレベルのOpExを削減します。',
        icon: 'tabler:cpu',
      },
      {
        title: '機能主導の収益化',
        description:
          'パーソナライゼーション、予測、自動化などのAI主導の価値提案を創出し、収益またはリテンション向上に直結させます。',
        icon: 'tabler:currency-dollar',
      },
      {
        title: 'ワークフォース・リイマジネーション',
        description:
          'AI拡張されたロールと継続的学習を通じて、タスク実行から高次の問題解決へとチームの転換を支援します。',
        icon: 'tabler:users-group',
      },
      {
        title: 'データ＆プロダクト継続性',
        description:
          'データ、モデル、実験のライフサイクルシステムを確立し、イノベーションを進化する市場ニーズに整合させます。',
        icon: 'tabler:refresh',
      },
    ]}
  />
</Layout>

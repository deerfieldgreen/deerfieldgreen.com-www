---
import Layout from '~/layouts/PageLayout.astro';
import HeroKintsugi from '~/components/widgets/v2/HeroKintsugi.astro';
import ContentKintsugi from '~/components/widgets/v2/ContentKintsugi.astro';
import FeaturesSeam from '~/components/widgets/v2/FeaturesSeam.astro';
import CTASumi from '~/components/widgets/v2/CTASumi.astro';

const metadata = {
  title: '会社概要',
  description:
    '東京都港区を拠点とするプライベート・クオンツ投資会社、ディアフィールド・グリーン。戦略的投資と目的ある慈善活動の融合。',
};
---

<Layout metadata={metadata}>
  <!-- Hero ************************ -->

  <HeroKintsugi
    primaryLang="ja"
    eyebrow="§ 01 / 会社について"
    titleEn="Thoughtful. Patient. Quantitative."
    titleJa="思慮深く。<br/>忍耐強く。<br/>定量的に。"
    subtitle="日本の卓越性とグローバル市場をつなぐブティック型投資・コンサルティング会社 — 定量的な厳密さ、環太平洋の専門知識、そして目的ある慈善活動を融合しています。"
    actions={[{ text: 'お問い合わせ', href: '/ja/contact/' }]}
  />

  <!-- Mission ********************* -->

  <ContentKintsugi
    id="mission"
    eyebrow="§ 02 / ミッション"
    title="私たちの使命"
    intro="ディアフィールド・グリーンは東京都港区に本社を置くプライベート・クオンツ投資会社です。私たちの使命は2つあります。グローバル市場でアルファを追求すること、そしてポートフォリオから得られる利回りを社会にポジティブな影響を与える慈善活動に振り向けることです。資本主義的な努力は、他の人々の生活を向上させるという深い目的意識と融合させることができると確信しています。"
    items={[
      {
        title: '目的あるアルファ',
        description:
          'データドリブンモデルと厳密な分析を活用し、グローバル市場でアルファを特定・獲得する定量的投資戦略を適用しています。',
      },
      {
        title: 'フィランソロピーを中心に',
        description:
          '私たちの投資理念は、日本文化の保護、奨学金、メンタルヘルスの推進といった慈善活動を唯一の目的として据えています。',
      },
      {
        title: '持続可能なインパクト',
        description:
          '強力な財務リターンを創出することで、慈善活動の持続可能性と長期的な成長を確保しています。',
      },
    ]}
    image={{
      src: '~/assets/images/team-work.jpg',
      alt: 'ディアフィールド・グリーンのチームコラボレーション',
    }}
  />

  <!-- Practice ******************** -->

  <FeaturesSeam
    id="services"
    eyebrow="§ 03 / 実践"
    title="サービス"
    subtitle="4つの実践、1つの理念 — 目的に資する定量的厳密さとペイシェント・キャピタル。"
    defaultLinkText="詳細 →"
    items={[
      {
        label: 'QUANT / AI',
        title: '投資',
        description:
          'AIを活用したNYSEおよびNASDAQへの定量的投資。リスク管理と非相関リターンによるアルファの創出に注力。',
      },
      {
        label: 'AI / SAAS',
        title: 'サービス',
        description:
          'SaaSビジネスのサブスクリプション収益拡大を支援。シリコンバレー、ヘルスケア、製造業など40社以上の実績。',
      },
      {
        label: 'HEALTHCARE / VC',
        title: 'インキュベーター',
        description:
          'インキュベーター型ベンチャーキャピタルモデルを通じて、日本のイノベーションをグローバルヘルスケア市場へつなぐ。',
      },
      {
        label: 'HEALTHCARE / PE',
        title: 'プライベート・エクイティ',
        description:
          '日本のヘルスケアPE革命 — オペレーショナル・エクセレンスを通じた卓越したリターンを実現するペイシェント・キャピタル。',
      },
    ]}
  />

  <!-- Values ********************** -->

  <ContentKintsugi
    id="values"
    eyebrow="§ 04 / 価値観"
    title="私たちの価値観"
    intro="東洋の叡智と西洋のイノベーションを架橋する原則に導かれて。"
    isReversed={true}
    items={[
      {
        title: 'ペイシェント・キャピタル哲学',
        description:
          '実践例：日本のヘルスケア・プライベートエクイティおよびインキュベーター投資における複数年の投資期間。四半期目標ではなく、現場の経営チームと臨床上のマイルストーンに資本を寄り添わせています。',
      },
      {
        title: '環太平洋の専門知識',
        description:
          '実践例：日本における医療イノベーションの規制対応、シリコンバレーのSaaS GTMを日本のエンタープライズ顧客向けに再設計すること、そして米国創業者と日本パートナーの間の文化的な翻訳層としての役割を担っています。',
      },
      {
        title: 'テクノロジー主導のアプローチ',
        description:
          '実践例：NYSEおよびNASDAQでリスク管理されたアルファを追求する独自のクオンツ戦略を運用し、AIプロダクト戦略案件ではモデル選定と推論コストを測定可能なビジネス成果に結びつけています。',
      },
    ]}
  />

  <!-- Locations ******************* -->

  <FeaturesSeam
    id="locations"
    eyebrow="§ 05 / 拠点"
    title="所在地"
    defaultLinkText="詳細 →"
    items={[
      {
        label: 'JAPAN / HQ',
        title: '東京都港区',
        description: '日本本社。',
      },
      {
        label: 'USA / OFFICE',
        title: 'ジョージア州ミルトン',
        description: '米国オフィス(アトランタ都市圏)。',
      },
    ]}
  />

  <!-- CTA ************************* -->

  <CTASumi
    primaryLang="ja"
    eyebrow="§ 06 / お問い合わせ"
    titleEn="Let's build together."
    titleJa="ご一緒に築きましょう。"
    subtitle="戦略コンサルティング、投資パートナーシップ、環太平洋の市場専門知識など、お気軽にご相談ください。"
    actions={[{ text: 'お問い合わせ', href: '/ja/contact/', variant: 'primary' }]}
  />
</Layout>

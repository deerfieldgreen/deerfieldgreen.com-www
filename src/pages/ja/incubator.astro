---
import Layout from '~/layouts/PageLayout.astro';

import HeroKintsugi from '~/components/widgets/v2/HeroKintsugi.astro';
import ContentKintsugi from '~/components/widgets/v2/ContentKintsugi.astro';
import FeaturesSeam from '~/components/widgets/v2/FeaturesSeam.astro';
import CTASumi from '~/components/widgets/v2/CTASumi.astro';

const metadata = {
  title: 'インキュベーター',
  description: '日本のイノベーションと世界のヘルスケア市場の架け橋',
};
---

<Layout metadata={metadata}>
  <HeroKintsugi
    eyebrow="§ 01 / INCUBATOR"
    titleJa="日本のイノベーションと世界のヘルスケア市場の架け橋。"
    titleEn="Bridging Japanese innovation with global healthcare markets."
    subtitle="環太平洋パートナーシップを通じた明日のヘルスケア・イノベーションのエンジニアリング。日本の研究エコシステムからグローバル市場のリーダーへと、ヘルスケア、バイオテクノロジー、AIによる医療イノベーションを育成します。"
    actions={[{ text: 'お問い合わせ', href: '/ja/contact/' }]}
    primaryLang="ja"
  />

  <ContentKintsugi
    id="intro"
    eyebrow="§ 02 / 投資哲学"
    title="環太平洋パートナーシップを通じた、明日のヘルスケア・イノベーション。"
    image={{ src: '~/assets/images/incubator.jpg', alt: 'インキュベーター・プログラム' }}
    intro="ディアフィールド・グリーンは、ヘルスケア・イノベーションの未来は、日本の卓越した技術、深い文化的叡智、そしてグローバルな市場展開の交差点にあると信じています。私たちのインキュベーター・スタイルのベンチャー・キャピタル・モデルは、東洋と西洋のビジネス哲学のユニークな統合であり、日本の並外れた研究エコシステムから、ヘルスケア、バイオテクノロジー、AIを活用した医療イノベーションを世界市場のリーダーへと育成するために特別に設計されています。"
    items={[
      {
        title: '25年の日米市場経験',
        description:
          '私たちは、日米両市場においてSaaS型収益企業を立ち上げ、その規模を拡大してきた25年の経験をもとに、世界で最も洗練された2つのヘルスケア・エコシステムの架け橋となるインキュベーター・モデルを構築しました。',
      },
      {
        title: 'ポートフォリオにおける「和」の力',
        description:
          'ディアフィールド・グリーンは、アグレッシブな成長を最優先する伝統的な欧米のベンチャーキャピタルとは異なり、日本の「和」の原則をポートフォリオ・アプローチに取り入れています。私たちは、常に10社以下のヘルスケアベンチャーに集中したポートフォリオを維持し、グローバルな市場競争に必要な緊急性を維持しながら、各企業が日本のビジネス関係の特徴である忍耐強く、思慮深いサポートを受けられるようにしています。',
      },
    ]}
  />

  <FeaturesSeam
    id="principles"
    eyebrow="§ 03 / 投資哲学の原則"
    title="日本の卓越性とグローバルな野心の調和。"
    subtitle="ファーストコンタクトからグローバル・スケールまで、創業者との関わり方を形作る4つの規律。"
    defaultLinkText="詳細 →"
    items={[
      {
        label: '根回し',
        title: '長期的な関係構築',
        description:
          '投資前に6〜18ヶ月間の関係構築に投資し、テクノロジーだけでなく、人々、彼らの価値観、社会的インパクトに対するビジョンを理解します。',
      },
      {
        label: '合意形成',
        title: 'コンセンサス主導の意思決定',
        description: '日本の伝統である集合知を尊重しつつ、起業家としての機敏性を維持する。',
      },
      {
        label: '創業者ビジョン',
        title: '創業者のビジョンの維持',
        description:
          '欧米の積極的なリストラとは異なり、創業者の当初の使命を尊重しながら、世界的な規模を達成するための運営サポートを提供する。',
      },
      {
        label: 'ペイシェント・キャピタル',
        title: 'ペイシェント・キャピタル・アプローチ',
        description:
          '日本の投資哲学に沿い、5〜7年の投資期間を維持し、イノベーションが適切に成熟するのを待つ。',
      },
    ]}
  />

  <FeaturesSeam
    id="focus"
    eyebrow="§ 04 / ヘルスケア重点分野"
    title="日本のイノベーションと世界のニーズの融合。"
    subtitle="人口の30％が65歳以上、10％が80歳以上という日本は、高齢化社会ソリューションの世界の実験場です。"
    defaultLinkText="詳細 →"
    items={[
      {
        label: 'AI診断',
        title: 'AIを活用した診断と精密医療',
        description: '日本の優れた医用画像データセットと高齢化関連疾患に対応するアルゴリズムの開発。説明可能なAIの構築。',
      },
      {
        label: 'バイオテック',
        title: 'バイオテクノロジーと医薬品イノベーション',
        description: '再生医療リーダーシップ、フラグメント創薬、天然物ライブラリー、抗体工学、AI主導のドラッグデザイン。',
      },
      {
        label: 'デジタルヘルス',
        title: 'デジタルヘルスと遠隔医療プラットフォーム',
        description:
          '2035年までに908.7億ドルに達すると予測されるデジタルヘルス市場。分断された医療提供体制に対応するプラットフォーム。',
      },
      {
        label: '長寿',
        title: '長寿とアンチエイジング治療薬',
        description: '日本のブルーゾーン哲学と最先端バイオテクノロジーの融合。AIを活用した高齢者ケアソリューション。',
      },
    ]}
  />

  <ContentKintsugi
    id="positioning"
    eyebrow="§ 05 / 日米の架け橋"
    title="地域のイノベーションを、グローバルなインパクトへ。"
    isReversed
    intro="東京都港区とジョージア州アトランタの2拠点体制は、医療イノベーションのための強力な回廊を形成しています。"
    items={[
      {
        title: '東京オペレーション：イノベーション・ハブ',
        description:
          '医薬品ベンチャー企業に対する62億円の政府資金援助プログラムへの直接アクセス。東京大学、慶應義塾大学、理化学研究所などの主要機関とのパートナーシップ。日本のバイオベンチャー企業の50％が拠点を置く大東京バイオコミュニティに近接。イノベーション・パートナーシップを求める日本の製薬大手との関係。',
      },
      {
        title: 'アトランタのオペレーション：商業化エンジン',
        description:
          '4.3兆ドル規模の米国医療市場へのゲートウェイ。CDC、エモリー大学、ジョージア工科大学の生物医学工学プログラムに近接。南東部の新興バイオテクノロジー回廊へのアクセス。米国のベンチャー・キャピタルや戦略的買収者との直接的なコネクション。',
      },
    ]}
  />

  <ContentKintsugi
    id="operations"
    eyebrow="§ 06 / オペレーション"
    title="オペレーショナル・フレームワーク。"
    intro="取引の前に信頼関係を築く日本の医療機関は広範な関係構築を必要とします。私たちは長期的パートナーシップの考え方を重視し、すべての顧客対応にバイリンガルサポートと文化通訳を提供します。"
    items={[
      {
        title: '事業開発：B2Bヘルスケアにおける「おもてなし」の極意',
        description:
          '取引の前に信頼関係を築く日本の医療機関は広範な関係構築を必要とする。マルチステークホルダー・ナビゲーション：医師、行政官、政府関係者が関わる複雑な意思決定を理解する。長期的パートナーシップの考え方を重視し、すべての顧客対応にバイリンガルサポートと文化通訳を提供する。',
      },
      {
        title: '卓越した研究開発',
        description:
          '反復による完璧さ：絶え間ない改良という日本のアプローチを取り入れる。日本の完璧主義とマーケット・タイミング要件のバランスをとり、日本の大学や研究機関とのパートナーシップを促進。すべての技術文書は日本語と英語で作成し、時差を利用した24時間の開発サイクルを実現。',
      },
    ]}
  />

  <CTASumi
    id="contact"
    eyebrow="§ 07 / CONTACT"
    titleJa="一緒に取り組みませんか。"
    titleEn="Partner with us."
    subtitle="私たちのインキュベーター・モデルがいかに日本のイノベーションとグローバルなヘルスケア市場を結びつけるかをご覧ください。"
    actions={[{ text: 'お問い合わせ', href: '/ja/contact/', variant: 'primary' }]}
    primaryLang="ja"
  />
</Layout>

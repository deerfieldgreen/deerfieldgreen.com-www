---
import Layout from '~/layouts/PageLayout.astro';
import HeroKintsugi from '~/components/widgets/v2/HeroKintsugi.astro';
import ContentKintsugi from '~/components/widgets/v2/ContentKintsugi.astro';
import CTASumi from '~/components/widgets/v2/CTASumi.astro';

const metadata = {
  title: 'Our Team',
  description: 'Blending Quantitative Investing with Purposeful Philanthropy',
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->
  <HeroKintsugi
    eyebrow="§ 01 / TEAM"
    titleEn="Blending Quantitative Investing with Purposeful Philanthropy"
    titleJa="クオンツ投資と目的ある慈善活動の融合"
    subtitle="A boutique firm experience — financial expertise paired with an intense humanity for improving the lives of others."
    primaryLang="en"
  />

  <!-- Founder ******************* -->
  <ContentKintsugi
    id="founder"
    eyebrow="§ 02 / FOUNDER"
    title="Kevin O'Neill Stoll"
    intro={`<span class="block font-mono text-[11px] tracking-[0.22em] uppercase text-[var(--aw-color-primary)] mb-4">Founder</span>Kevin Stoll, hailing from Alpharetta, Georgia, USA, brings over 20 years of expertise in advising Subscription Economy companies on growth strategies. A data enthusiast with a deep interest in financial markets and Japanese culture, he combines diverse perspectives to drive impactful results.<br/><br/><a href="https://www.linkedin.com/company/deerfieldgreen/" target="_blank" rel="noopener noreferrer" class="kintsugi-link font-sans text-[14px] tracking-wide">Follow Deerfield Green on LinkedIn →</a>`}
    items={[
      { title: 'Tokyo & Atlanta', description: 'Based between Minato-ku, Tokyo, and the greater Atlanta area.' },
      { title: '20+ years advisory', description: 'Growth strategy for Subscription Economy companies.' },
      { title: 'Data & Japanese culture', description: 'A data enthusiast with deep interest in financial markets and Japanese culture.' },
    ]}
    image={{ src: '~/assets/images/team-1.jpg', alt: 'Kevin Stoll' }}
    isReversed
  />

  <!-- Mission ******************* -->
  <ContentKintsugi
    id="mission"
    eyebrow="§ 03 / MISSION"
    title="Alpha in service of purpose."
    intro="Deerfield Green is a private quantitative investment firm based in Minato-ku, Tokyo, Japan. Our mission is twofold: seeking alpha across global markets and channeling the yields from our portfolio into philanthropic endeavors that make a positive impact on society. We firmly believe that capitalistic endeavors can be blended with a deep sense of purpose to empower and improve the lives of others."
    items={[
      {
        title: 'Quantitative investment thesis',
        description:
          'We apply data-driven models and rigorous analysis to identify and capture alpha in global markets, ensuring the sustainability and growth of our philanthropic initiatives.',
      },
      {
        title: 'Japanese culture and arts',
        description:
          'We invest in initiatives that promote Japanese cultural preservation, nurture artistic talent, and provide platforms for cultural expression.',
      },
      {
        title: 'Opportunity for those in need',
        description:
          'Educational programs, vocational training, and entrepreneurship initiatives that empower individuals to unlock their potential and build sustainable futures.',
      },
      {
        title: 'Mental health growth',
        description:
          'Counseling, therapy, awareness campaigns, and research that prioritize holistic well-being and resilience.',
      },
      {
        title: 'A boutique firm experience',
        description:
          'While driven by quantitative strategies, we offer a boutique experience characterized by an intense humanity for improving the lives of others.',
      },
    ]}
  />

  <!-- CTA ******************* -->
  <CTASumi
    id="contact"
    eyebrow="§ 04 / CONTACT"
    titleEn="Start a conversation."
    titleJa="お話ししましょう。"
    subtitle="Reach out — whether about investment, philanthropy, or a shared curiosity."
    actions={[{ variant: 'primary', text: 'Begin a conversation', href: '/contact/' }]}
    primaryLang="en"
  />
</Layout>

---
import Layout from '~/layouts/PageLayout.astro';
import HeroKintsugi from '~/components/widgets/v2/HeroKintsugi.astro';
import FeaturesSeam from '~/components/widgets/v2/FeaturesSeam.astro';
import CTASumi from '~/components/widgets/v2/CTASumi.astro';

const metadata = {
  title: 'Insights',
  description: 'Curated insights from the Deerfield Green team',
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->
  <HeroKintsugi
    eyebrow="§ 01 / INSIGHTS"
    titleEn="Curated Insights."
    titleJa="厳選されたインサイト。"
    subtitle="A working library from the Deerfield Green team — books, whitepapers, articles, frameworks, newsletter, and prototypes that shape our thinking."
    primaryLang="en"
  />

  <!-- Catalog ******************* -->
  <FeaturesSeam
    id="catalog"
    eyebrow="§ 02 / CATALOG"
    title="Our working library."
    subtitle="Each channel lives at its own subdomain — explore as needed."
    items={[
      {
        label: 'BOOKS',
        title: 'Books',
        description:
          'Recommended reading from our team — titles that have shaped our thinking on investment, strategy, and innovation.',
        href: 'https://books.deerfieldgreen.com/',
        linkText: 'View books →',
      },
      {
        label: 'WHITEPAPERS',
        title: 'Whitepapers',
        description:
          'In-depth research and analysis on topics shaping investment, technology, and strategy.',
        href: 'https://whitepapers.deerfieldgreen.com/',
        linkText: 'View whitepapers →',
      },
      {
        label: 'ARTICLES',
        title: 'Articles',
        description: 'Selected articles and publications by our team and partners.',
        href: '/articles/',
        linkText: 'View all articles →',
      },
      {
        label: 'FRAMEWORKS',
        title: 'Frameworks',
        description:
          'Proprietary and open frameworks we use to guide decision-making, strategy, and analysis.',
        href: 'https://frameworks.deerfieldgreen.com/',
        linkText: 'View frameworks →',
      },
      {
        label: 'NEWSLETTER',
        title: 'Newsletter',
        description:
          'Regular updates on our latest thinking, market insights, and firm news.',
        href: 'https://newsletter.deerfieldgreen.com/',
        linkText: 'View newsletter →',
      },
      {
        label: 'PROTOTYPES',
        title: 'Prototypes',
        description:
          'Experimental projects and proof-of-concept work from our incubator and research teams.',
        href: 'https://prototypes.deerfieldgreen.com/',
        linkText: 'View prototypes →',
      },
    ]}
  />

  <!-- CTA ******************* -->
  <CTASumi
    id="contact"
    eyebrow="§ 03 / CONTACT"
    titleEn="Want to go deeper?"
    titleJa="さらに深く知りたい方へ。"
    subtitle="Reach out and we'll point you to the right material — or start a conversation."
    actions={[{ variant: 'primary', text: 'Begin a conversation', href: '/contact/' }]}
    primaryLang="en"
  />
</Layout>

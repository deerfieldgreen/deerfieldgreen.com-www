---
import Features2 from '~/components/widgets/Features2.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Insights',
  description: 'Curated insights from the Deerfield Green team',
};
---

<Layout metadata={metadata}>
  <!-- HeroText Widget ******************* -->

  <HeroText
    tagline="Insights"
    title="Curated Insights"
    subtitle="Curated insights from the Deerfield Green team"
  />

  <!-- Insights Grid ******************* -->

  <Features2
    title="Our Insights"
    columns={2}
    items={[
      {
        title: 'Books',
        description:
          'Recommended reading from our team — titles that have shaped our thinking on investment, strategy, and innovation.',
        icon: 'tabler:book',
        callToAction: {
          text: 'View books',
          href: 'https://books.deerfieldgreen.com/',
        },
      },
      {
        title: 'Whitepapers',
        description:
          'In-depth research and analysis on topics shaping investment, technology, and strategy.',
        icon: 'tabler:file-text',
        callToAction: {
          text: 'View whitepapers',
          href: 'https://whitepapers.deerfieldgreen.com/',
        },
      },
      {
        title: 'Articles',
        description:
          'Selected articles and publications by our team and partners.',
        icon: 'tabler:article',
        callToAction: {
          text: 'View all articles',
          href: '/articles/',
        },
      },
      {
        title: 'Frameworks',
        description:
          'Proprietary and open frameworks we use to guide decision-making, strategy, and analysis.',
        icon: 'tabler:sitemap',
        callToAction: {
          text: 'View frameworks',
          href: 'https://frameworks.deerfieldgreen.com/',
        },
      },
      {
        title: 'Newsletter',
        description:
          'Regular updates on our latest thinking, market insights, and firm news.',
        icon: 'tabler:mail',
        callToAction: {
          text: 'View newsletter',
          href: 'https://newsletter.deerfieldgreen.com/',
        },
      },
      {
        title: 'Prototypes',
        description:
          'Experimental projects and proof-of-concept work from our incubator and research teams.',
        icon: 'tabler:flask',
        callToAction: {
          text: 'View prototypes',
          href: 'https://prototypes.deerfieldgreen.com/',
        },
      },
    ]}
  />
</Layout>

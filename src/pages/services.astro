---
import Layout from '~/layouts/PageLayout.astro';

import HeroKintsugi from '~/components/widgets/v2/HeroKintsugi.astro';
import ContentKintsugi from '~/components/widgets/v2/ContentKintsugi.astro';
import FeaturesSeam from '~/components/widgets/v2/FeaturesSeam.astro';
import CTASumi from '~/components/widgets/v2/CTASumi.astro';
import SeamDivider from '~/components/common/SeamDivider.astro';

const metadata = {
  title: 'Services',
  description: 'SaaS subscription revenue consulting and AI product strategy — where data-driven growth meets intelligent innovation.',
};
---

<Layout metadata={metadata}>
  <!-- Hero ******************* -->

  <HeroKintsugi
    eyebrow="§ 01 / SERVICES"
    titleEn="AI Product Strategy &amp; SaaS Growth"
    titleJa="AI プロダクト戦略 と SaaS グロース"
    subtitle="Two disciplines under one roof. We help technology companies weave AI adoption and subscription growth together — so intelligent products compound into durable ARR."
    actions={[
      {
        variant: 'primary',
        text: 'Begin a conversation',
        href: '/contact/',
      },
    ]}
    primaryLang="en"
  />

  <!-- AI Product Strategy — narrative + image ******************* -->

  <ContentKintsugi
    id="ai"
    eyebrow="§ 02 / AI PRODUCT STRATEGY"
    title="Where intelligent vision meets measurable impact."
    intro="Deerfield Green partners with forward-looking leaders to transform artificial intelligence from potential into performance. We help organizations design and scale AI-enabled products that redefine customer experience and drive capital efficiency and operational ROI."
    items={[
      {
        title: 'Clarity of purpose, measurable change.',
        description:
          'Effective AI strategy begins with a defined business question and ends with an observed shift in outcomes. We pair visionary product thinking with pragmatic execution.',
      },
      {
        title: 'Self-reinforcing systems and models.',
        description:
          'We architect systems and business models that make AI investment compound — where better data feeds better features, and better features fund better data.',
      },
      {
        title: 'Executives, product, and data — aligned.',
        description:
          'We collaborate across leadership, product teams, and data organizations to define enterprise-wide AI vision, scalable architectures, monetization pathways, and transparent governance.',
      },
    ]}
    image={{ src: '~/assets/images/services-ai.jpg', alt: 'AI technology and data visualization' }}
  />

  <!-- Unsplash attribution — AI image ******************* -->

  <div class="max-w-7xl mx-auto px-6 md:px-10 -mt-6 mb-12 text-right">
    <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-[var(--aw-color-text-subtle)]">
      Photo by <a href="https://unsplash.com/@growtika?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Growtika</a> · <a href="https://unsplash.com/?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Unsplash</a>
    </p>
  </div>

  <!-- AI Strategy services — seam list ******************* -->

  <FeaturesSeam
    id="ai-services"
    eyebrow="§ 03 / AI ADVISORY"
    title="AI Strategy Services"
    subtitle="Building the systems and disciplines that let AI scale sustainably across your organization."
    items={[
      {
        label: 'ROI',
        title: 'AI ROI Modeling',
        description:
          'Connecting investment to business outcomes through detailed performance metrics, payback analysis, and growth projections.',
      },
      {
        label: 'EFFICIENCY',
        title: 'Intelligent Cost Efficiency',
        description:
          'Reducing token-level OpEx through optimized inference pipelines, caching strategies, and adaptive model routing.',
      },
      {
        label: 'MONETIZATION',
        title: 'Feature-Led Monetization',
        description:
          'Creating AI-driven value propositions — personalization, prediction, automation — that convert directly into revenue or retention lift.',
      },
      {
        label: 'WORKFORCE',
        title: 'Workforce Reimagination',
        description:
          'Guiding teams to shift from task execution to higher-order problem-solving through AI-augmented roles and continuous learning.',
      },
      {
        label: 'CONTINUITY',
        title: 'Data & Product Continuity',
        description:
          'Establishing lifecycle systems for data, models, and experimentation that keep innovation aligned with evolving market needs.',
      },
    ]}
  />

  <SeamDivider variant="default" tone="light" />

  <!-- SaaS Subscription Growth — narrative + image ******************* -->

  <ContentKintsugi
    id="saas"
    eyebrow="§ 04 / SAAS GROWTH"
    title="Subscription revenue, engineered for compounding."
    intro="Deerfield Green helps SaaS businesses grow subscription revenue across three sectors we know well: Silicon Valley SaaS, healthtech, and industrial and manufacturing technology. Over 40 engagements have centered on the same outcomes — ARR expansion, churn reduction, and pricing and packaging resets."
    items={[
      {
        title: 'Start where the business actually sits.',
        description:
          'Which cohorts are leaking, which segments are under-priced, which products are carrying the retention curve. Every engagement begins with that diagnosis — not a template.',
      },
      {
        title: 'Plans built for the real market.',
        description:
          'We build a subscription revenue plan that fits the specific market, buyer, and competitive reality — spanning pricing and packaging, go-to-market motion, and retention programs.',
      },
      {
        title: 'ARR that compounds across years.',
        description:
          'The work is designed for multi-year horizons: direct, channel, and product-led motion paired with retention and expansion programs that make growth self-sustaining.',
      },
    ]}
    image={{ src: '~/assets/images/services-saas.jpg', alt: 'Team brainstorming strategy with sticky notes' }}
    isReversed={true}
  />

  <!-- Unsplash attribution — SaaS image ******************* -->

  <div class="max-w-7xl mx-auto px-6 md:px-10 -mt-6 mb-12 text-right">
    <p class="font-mono text-[10px] tracking-[0.2em] uppercase text-[var(--aw-color-text-subtle)]">
      Photo by <a href="https://unsplash.com/@silverkblack?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Vitaly Gariev</a> · <a href="https://unsplash.com/?utm_source=deerfieldgreen&utm_medium=referral" class="underline hover:text-[var(--aw-color-primary)]" target="_blank" rel="noopener noreferrer">Unsplash</a>
    </p>
  </div>

  <!-- SaaS Advisory — seam list ******************* -->

  <FeaturesSeam
    id="saas-services"
    eyebrow="§ 05 / SAAS ADVISORY"
    title="SaaS Growth Services"
    subtitle="A holistic approach to sustainable subscription revenue growth."
    items={[
      {
        label: 'SALES',
        title: 'Direct and Channel Sales',
        description:
          'Building and optimizing direct and channel sales strategies to maximize reach and revenue.',
      },
      {
        label: 'MARKETING',
        title: 'Subscription Marketing Strategy',
        description:
          'Developing targeted marketing strategies designed to acquire and retain subscription customers.',
      },
      {
        label: 'DATA',
        title: 'Data Strategy',
        description:
          'Leveraging data analytics to inform decision-making and drive business growth.',
      },
      {
        label: 'FINANCE',
        title: 'Finance',
        description:
          'Financial planning and modeling to ensure sustainable growth and profitability.',
      },
      {
        label: 'PLG',
        title: 'Product Led Growth',
        description:
          'Implementing product-led growth strategies that drive adoption and expansion revenue.',
      },
    ]}
  />

  <!-- CTA ******************* -->

  <CTASumi
    eyebrow="§ 06 / CONTACT"
    titleEn="Ready to transform your business?"
    titleJa="ビジネスの変革を、ともに。"
    subtitle="Let's discuss how Deerfield Green can help you connect intelligent product strategy with durable subscription growth."
    actions={[
      {
        variant: 'primary',
        text: 'Begin a conversation',
        href: '/contact/',
      },
    ]}
    primaryLang="en"
  />
</Layout>

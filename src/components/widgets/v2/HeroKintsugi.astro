---
import PaperGrain from '~/components/common/PaperGrain.astro';
import SeamDivider from '~/components/common/SeamDivider.astro';

import type { CallToAction } from '~/types';

interface Props {
  eyebrow?: string;
  titleEn?: string;
  titleJa?: string;
  subtitle?: string;
  actions?: CallToAction[];
  /** Which of the two title lines is primary (gets the <h1> + no lang attr). */
  primaryLang?: 'en' | 'ja';
}

const {
  eyebrow = await Astro.slots.render('eyebrow'),
  titleEn = await Astro.slots.render('titleEn'),
  titleJa = await Astro.slots.render('titleJa'),
  subtitle = await Astro.slots.render('subtitle'),
  actions = await Astro.slots.render('actions'),
  primaryLang = 'en',
} = Astro.props;

// Resolve primary vs secondary content and their lang attrs.
const primaryTitle = primaryLang === 'ja' ? titleJa : titleEn;
const secondaryTitle = primaryLang === 'ja' ? titleEn : titleJa;
const primaryLangAttr = primaryLang === 'ja' ? 'ja' : undefined;
const secondaryLangAttr = primaryLang === 'ja' ? 'en' : 'ja';
---

<section
  class="relative overflow-hidden md:-mt-[76px] min-h-[85vh] md:min-h-[92vh] pt-[120px] md:pt-[180px] pb-24 md:pb-32 bg-[var(--aw-color-bg-page)]"
>
  <PaperGrain tone="light" opacity={0.04} />

  <div
    class="absolute top-0 bottom-0 w-px bg-[var(--aw-color-border)] right-[8%] md:right-[12%] pointer-events-none"
    aria-hidden="true"
  >
  </div>

  <div class="relative max-w-7xl mx-auto px-6 md:px-10 md:grid md:grid-cols-12 md:gap-6">
    <div class="md:col-span-10 md:col-start-2">
      {
        eyebrow && (
          <p
            class="font-mono text-[11px] md:text-xs tracking-[0.22em] uppercase text-[var(--aw-color-text-muted)] mb-16 md:mb-24 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
            style="animation-delay: 0ms;"
            set:html={eyebrow}
          />
        )
      }

      {
        primaryTitle && (
          <h1
            {...(primaryLangAttr ? { lang: primaryLangAttr } : {})}
            class="font-heading font-normal leading-[1.02] tracking-[-0.015em] text-[var(--aw-color-text-heading)] text-[44px] sm:text-6xl md:text-[84px] lg:text-[104px] max-w-[14ch] intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
            style="animation-delay: 80ms;"
            set:html={primaryTitle}
          />
        )
      }

      {
        secondaryTitle && (
          <p
            lang={secondaryLangAttr}
            class="font-heading font-normal leading-[1.3] text-[var(--aw-color-text-muted)] text-[26px] md:text-[44px] lg:text-[52px] tracking-[0.02em] mt-6 md:mt-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
            style="animation-delay: 200ms;"
            set:html={secondaryTitle}
          />
        )
      }

      <div
        class="intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
      >
        <SeamDivider variant="inline" tone="light" class="mt-10 md:mt-12" />
      </div>

      {
        subtitle && (
          <p
            class="mt-10 md:mt-14 max-w-[52ch] text-lg md:text-xl leading-relaxed text-[var(--aw-color-text-default)] font-sans intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
            style="animation-delay: 420ms;"
            set:html={subtitle}
          />
        )
      }

      {
        actions && Array.isArray(actions) && actions.length > 0 && (
          <div
            class="mt-10 md:mt-14 flex flex-wrap gap-x-10 gap-y-4 items-center intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
            style="animation-delay: 540ms;"
          >
            {actions.map((action) => (
              <a class="kintsugi-link font-sans text-[15px] tracking-wide" href={action.href}>
                <span>{action.text}</span>
                <span aria-hidden="true" class="text-[var(--aw-color-primary)]">→</span>
              </a>
            ))}
          </div>
        )
      }

      {
        actions && !Array.isArray(actions) && (
          <div
            class="mt-10 md:mt-14 flex flex-wrap gap-x-10 gap-y-4 items-center intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
            style="animation-delay: 540ms;"
          >
            <Fragment set:html={actions} />
          </div>
        )
      }
    </div>
  </div>

  <div
    class="hidden md:flex flex-col items-end gap-1 absolute bottom-10 right-10 font-mono text-[10px] tracking-[0.25em] uppercase text-[var(--aw-color-text-subtle)]"
    aria-hidden="true"
  >
    <span>§ 01 / FIRM</span>
  </div>
</section>

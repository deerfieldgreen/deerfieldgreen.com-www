---
import PaperGrain from '~/components/common/PaperGrain.astro';
import SeamDivider from '~/components/common/SeamDivider.astro';

interface Action {
  text: string;
  href: string;
  variant?: 'primary' | 'secondary';
}

interface Props {
  id?: string;
  eyebrow?: string;
  titleEn?: string;
  titleJa?: string;
  subtitle?: string;
  actions?: Action[];
  /** Which of the two title lines is primary (gets the <h2> + no lang attr). */
  primaryLang?: 'en' | 'ja';
}

const {
  id,
  eyebrow = await Astro.slots.render('eyebrow'),
  titleEn = await Astro.slots.render('titleEn'),
  titleJa = await Astro.slots.render('titleJa'),
  subtitle = await Astro.slots.render('subtitle'),
  actions = [],
  primaryLang = 'en',
} = Astro.props;

const primaryTitle = primaryLang === 'ja' ? titleJa : titleEn;
const secondaryTitle = primaryLang === 'ja' ? titleEn : titleJa;
const primaryLangAttr = primaryLang === 'ja' ? 'ja' : undefined;
const secondaryLangAttr = primaryLang === 'ja' ? 'en' : 'ja';

// Determine primary action: explicit variant === 'primary', else first action.
let primaryIndex = -1;
if (Array.isArray(actions) && actions.length > 0) {
  const explicit = actions.findIndex((a) => a && a.variant === 'primary');
  primaryIndex = explicit !== -1 ? explicit : 0;
}
---

<section
  {...id ? { id } : {}}
  class="relative overflow-hidden bg-[var(--aw-color-bg-sumi)] text-[var(--aw-color-text-on-sumi)] py-28 md:py-40"
>
  <PaperGrain tone="sumi" opacity={0.06} />

  <SeamDivider
    variant="default"
    tone="sumi"
    class="absolute top-16 left-0 right-0 px-6 md:px-10 max-w-7xl mx-auto"
  />

  <div class="max-w-5xl mx-auto px-6 md:px-10 relative text-center md:text-left">
    {
      eyebrow && (
        <p
          class="font-mono text-[11px] tracking-[0.22em] uppercase text-[var(--aw-color-primary)] mb-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          style="animation-delay: 0ms;"
          set:html={eyebrow}
        />
      )
    }

    {
      primaryTitle && (
        <h2
          {...(primaryLangAttr ? { lang: primaryLangAttr } : {})}
          class="font-heading font-normal text-4xl md:text-6xl lg:text-7xl leading-[1.05] tracking-[-0.01em] text-[var(--aw-color-text-on-sumi)] intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          style="animation-delay: 80ms;"
          set:html={primaryTitle}
        />
      )
    }

    {
      secondaryTitle && (
        <p
          lang={secondaryLangAttr}
          class="font-heading font-normal text-2xl md:text-[40px] leading-[1.3] tracking-[0.02em] text-[rgb(234_228_216_/_70%)] mt-5 md:mt-7 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          style="animation-delay: 200ms;"
          set:html={secondaryTitle}
        />
      )
    }

    {
      subtitle && (
        <p
          class="mt-8 md:mt-10 text-lg md:text-xl leading-relaxed text-[rgb(234_228_216_/_78%)] max-w-[56ch] mx-auto md:mx-0 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          style="animation-delay: 320ms;"
          set:html={subtitle}
        />
      )
    }

    {
      Array.isArray(actions) && actions.length > 0 && (
        <div
          class="mt-12 md:mt-16 flex flex-wrap gap-6 justify-center md:justify-start items-center intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
          style="animation-delay: 440ms;"
        >
          {actions.map((action, idx) =>
            idx === primaryIndex ? (
              <a
                href={action.href}
                class="group inline-flex items-center gap-3 border border-[var(--aw-color-primary)] text-[var(--aw-color-primary)] px-7 py-4 font-sans text-[14px] tracking-[0.18em] uppercase transition-colors duration-300 hover:bg-[var(--aw-color-primary)] hover:text-[var(--aw-color-bg-sumi)]"
              >
                <span>{action.text}</span>
                <span
                  aria-hidden="true"
                  class="transition-transform duration-300 group-hover:translate-x-1"
                >
                  →
                </span>
              </a>
            ) : (
              <a
                href={action.href}
                class="kintsugi-link font-sans text-[15px] tracking-wide !text-[var(--aw-color-text-on-sumi)]"
              >
                <span>{action.text}</span>
                <span aria-hidden="true" class="text-[var(--aw-color-primary)]">
                  →
                </span>
              </a>
            )
          )}
        </div>
      )
    }
  </div>

  <div
    class="hidden md:block absolute bottom-10 right-10 font-mono text-[10px] tracking-[0.25em] uppercase text-[rgb(234_228_216_/_40%)]"
    aria-hidden="true"
  >
    DEERFIELD GREEN · MMXXVI
  </div>
</section>

---
// SeamDivider — the kintsugi gold-seam motif.
//
// Renders a horizontal hairline with an asymmetric gold inflection
// near its right third, stylized as a repaired seam. Used between
// major sections across the site.
//
// Variants:
//   variant="default"  — full width, used as a section break
//   variant="inline"   — shorter, sits beneath a bilingual headline in the hero
//   variant="mark"     — just the gold mark, no hairline (decorative)
//
// Tone:
//   tone="light"       — for washi backgrounds (default)
//   tone="sumi"        — for sumi-black backgrounds
//
// Animated: by default the seam draws in from the left on scroll.

interface Props {
  variant?: 'default' | 'inline' | 'mark';
  tone?: 'light' | 'sumi';
  class?: string;
  animated?: boolean;
}

const { variant = 'default', tone = 'light', class: className = '', animated = true } = Astro.props;

const baseLineColor = tone === 'sumi' ? 'rgb(234 228 216 / 22%)' : 'rgb(17 15 13 / 18%)';
const markColor = 'var(--aw-color-primary)';

const animClass = animated
  ? 'intersect-once intersect-quarter motion-safe:md:origin-left motion-safe:md:[transform:scaleX(0)] motion-safe:md:intersect:animate-seam-draw'
  : '';
---

{
  variant === 'mark' && (
    <span aria-hidden="true" class={`inline-block align-middle ${className}`} style={`color: ${markColor};`}>
      <svg width="18" height="12" viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path
          d="M2 6 L7 4 L9 8 L13 2 L16 7"
          stroke="currentColor"
          stroke-width="1.25"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
      </svg>
    </span>
  )
}

{
  variant === 'inline' && (
    <div class={`relative flex items-center w-full max-w-[520px] ${animClass} ${className}`} aria-hidden="true">
      <span class="block h-px flex-1" style={`background-color: ${baseLineColor};`} />
      <span class="mx-3 translate-y-[-1px]" style={`color: ${markColor};`}>
        <svg width="16" height="10" viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path
            d="M2 6 L7 4 L9 8 L13 2 L16 7"
            stroke="currentColor"
            stroke-width="1.25"
            stroke-linecap="round"
            stroke-linejoin="round"
            fill="none"
          />
        </svg>
      </span>
      <span class="block h-px w-12" style={`background-color: ${markColor};`} />
    </div>
  )
}

{
  variant === 'default' && (
    <div class={`relative w-full ${animClass} ${className}`} aria-hidden="true">
      <div class="relative h-px w-full" style={`background-color: ${baseLineColor};`}>
        {/* Gold seam inflection at ~70% from the left */}
        <span
          class="absolute top-1/2 -translate-y-1/2 h-px"
          style={`left: 66%; width: 14%; background-color: ${markColor};`}
        />
        <span
          class="absolute top-1/2 -translate-y-1/2 translate-x-[-50%]"
          style={`left: 80%; color: ${markColor};`}
        >
          <svg width="14" height="10" viewBox="0 0 18 12" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path
              d="M2 6 L7 4 L9 8 L13 2 L16 7"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-linecap="round"
              stroke-linejoin="round"
              fill="none"
            />
          </svg>
        </span>
      </div>
    </div>
  )
}

---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/dm-sans';
---

<style is:inline>
  :root {
    --aw-font-sans: 'DM Sans Variable';
    --aw-font-serif: 'Fraunces Variable';
    --aw-font-heading: 'Fraunces Variable';

    --aw-color-primary: rgb(196 168 130);
    --aw-color-secondary: rgb(61 56 50);
    --aw-color-accent: rgb(196 168 130);

    --aw-color-text-heading: rgb(26 26 26);
    --aw-color-text-default: rgb(61 56 50);
    --aw-color-text-muted: rgb(107 101 96);
    --aw-color-bg-page: rgb(250 250 248);

    --aw-color-text-subtle: rgb(140 133 126);
    --aw-color-bg-surface: rgb(245 243 240);
    --aw-color-border: rgb(232 228 223);

    --aw-color-bg-page-dark: rgb(3 6 32);

    ::selection {
      background-color: rgb(196 168 130 / 30%);
    }
  }
</style>
